        theme_swatch_row([
          theme_swatch_span("Theme.Danger", theme.danger, theme.foreground),
          theme_text_span("Theme.DangerText", theme.danger_text),
        ]),
      ]),
      theme_group("text and selection", [
        theme_swatch_row([
          theme_text_span("Theme.MutedForeground", theme.muted_foreground),
          theme_text_span("Theme.DisabledForeground", theme.disabled_foreground),
        ]),
        theme_swatch_row([
          theme_swatch_span("Theme.Selection", theme.selection, theme.foreground),
        ]),
      ]),
      ui::sized_box(0, 1, ui::text("")),
      ui::rich_text([ui::span("Palette tones", attrs: ui::TextAttrs{bold: true})]),
      palette_scale("neutral", theme.palette.neutral),
      palette_scale("red",     theme.palette.red),
      palette_scale("green",   theme.palette.green),
      palette_scale("yellow",  theme.palette.yellow),
      palette_scale("blue",    theme.palette.blue),
      palette_scale("magenta", theme.palette.magenta),
      palette_scale("cyan",    theme.palette.cyan),
    ],
    cross_align: ui::CrossAlign::start,
  )
}

// ─── Header & Footer ──────────────────────────────────────────────────

fn page_name(index: Int) Str {
  if index == 0 { "Home" }
  else if index == 1 { "Text" }
  else if index == 2 { "Controls" }
  else if index == 3 { "Lists" }
  else if index == 4 { "Table" }
  else if index == 5 { "Animation" }
  else if index == 6 { "Theme" }
  else { "?" }
}

fn page_slug(index: Int) Str {
  if index == 0 { "home" }
  else if index == 1 { "text" }
  else if index == 2 { "controls" }
  else if index == 3 { "lists" }
  else if index == 4 { "table" }
  else if index == 5 { "animation" }
  else if index == 6 { "theme" }
  else { "?" }
}

// Navigate to `target_page` and (if Animation) restart the controller
// so the page is interesting to look at on entry. Matches upstream's
// setPage trigger.
fn go_to_page(model: DemoState, state: ui::State<DemoState>, target: Int) {
  state.set(fn(mut s: DemoState) { s.page = target })
  if target == animation_page_index() {
    match model.anim {
      ctrl => ui::anim_forward(ctrl),
      _ => {},
    }
  }
}

fn build_header(page: Int, model: DemoState, state: ui::State<DemoState>, theme: ui::Theme) ui::Widget {
  mut tabs: [ui::Widget] = []
  // Ard `..` is inclusive on both ends; use n-1 for n iterations.
  // `for` provides an immutable per-iteration `i`, so closures capture
  // the right value automatically (no `let frozen = i` needed).
  for i in 0..(page_count() - 1) {
    if i > 0 {
      tabs.push(ui::sized_box(1, 1, ui::text("")))
    }
    mut tab_theme = theme
    if i == page {
      tab_theme.surface = theme.primary
      tab_theme.surface_hovered = theme.primary_hovered
    }
    tabs.push(ui::provider_theme(tab_theme, ui::button(page_name(i), fn(ctx: ui::EventContext) {
      go_to_page(model, state, i)
    })))
  }
  ui::column([
    ui::rich_text([
      ui::span("Vaxis UI demo", attrs: ui::TextAttrs{bold: true}),
      ui::span("  —  Alt+K commands, n/p pages, Tab focus, q quit"),
    ], false),
    ui::row(tabs, ui::MainAlign::center),
  ])
}

fn build_footer(page: Int) ui::Widget {
  let total = page_count()
  ui::row(
    [ui::rich_text(
      [
        ui::span("page "),
        ui::span((page + 1).to_str(), attrs: ui::TextAttrs{bold: true}),
        ui::span(" / " + total.to_str() + "  " + page_slug(page)),
      ],
      soft_wrap: false,
    )],
    main_align: ui::MainAlign::end,
  )
}

// ─── Page router ──────────────────────────────────────────────────────

fn build_page(model: DemoState, state: ui::State<DemoState>, theme: ui::Theme) ui::Widget {
  match model.page {
    0 => home_page(model.ticks),
    1 => text_page(theme),
    2 => controls_page(model, state, theme),
    3 => lists_page(model, state, theme),
    4 => table_page(),
    5 => animation_page(model, theme),
    6 => theme_page(theme),
    _ => home_page(model.ticks),
  }
}

// ─── Root widget ──────────────────────────────────────────────────────

fn keyboard_shortcuts() [Str:Str] {
  [
    "q": demo_quit(),
    "n": demo_next(),
    "p": demo_prev(),
    "d": demo_dialog(),
    "Alt+k": demo_palette(),
  ]
}

// Build the full set of command palette entries: one per page +
// dialog, animation, notify, quit.
fn build_palette_items(model: DemoState, state: ui::State<DemoState>) [ui::CmdItem] {
  mut items: [ui::CmdItem] = []
  // Ard `..` is inclusive on both ends; use n-1 for n iterations.
  for i in 0..(page_count() - 1) {
    let label = page_name(i)
    let slug = page_slug(i)
    items.push(ui::cmd_item(
      title: "Go to " + label,
      description: "Open the " + slug + " demo page",
      aliases: [slug, "page"],
      on_selected: fn(ctx: ui::EventContext) {
        state.set(fn(mut s: DemoState) {
          s.page = i
          s.palette_open = false
        })
        if i == animation_page_index() {
          match model.anim {
            ctrl => ui::anim_forward(ctrl),
            _ => {},
          }
        }
      },
    ))
  }
  items.push(ui::cmd_item(
    title: "Open dialog",
    description: "Show the modal dialog example",
    aliases: ["modal"],
    on_selected: fn(ctx: ui::EventContext) {
      state.set(fn(mut s: DemoState) {
        s.palette_open = false
        s.dialog_open = true
      })
    },
  ))
  items.push(ui::cmd_item(
    title: "Replay animation",
    description: "Start the animation controller",
    aliases: ["play"],
    on_selected: fn(ctx: ui::EventContext) {
      match model.anim {
        ctrl => ui::anim_forward(ctrl),
        _ => {},
      }
      state.set(fn(mut s: DemoState) { s.palette_open = false })
    },
  ))
  items.push(ui::cmd_item(
    title: "Send notification",
    description: "Show a demo notification",
    aliases: ["notify"],
    on_selected: fn(ctx: ui::EventContext) {
      ui::notify(ctx, "Vaxis UI demo", "Command palette action")
      state.set(fn(mut s: DemoState) { s.palette_open = false })
    },
  ))
  items.push(ui::cmd_item(
    title: "Quit",
    description: "Exit the demo",
    aliases: ["exit"],
    on_selected: fn(ctx: ui::EventContext) { ui::quit(ctx) },
  ))
  items
}

fn root_widget() ui::Widget {
  ui::stateful(
    key: "demo",
    init: fn(ctx: ui::BuildContext) DemoState {
      let rt = ctx.runtime<DemoState>()
      // Drive `ticks` from a background fiber to demonstrate Runtime
      // re-entry (mirrors the upstream Go demo's goroutine + Dispatch).
      async::start(fn() {
        while {
          async::sleep(duration::from_seconds(1))
          rt.dispatch(fn(state: ui::State<DemoState>) {
            state.set(fn(mut s: DemoState) { s.ticks = s.ticks + 1 })
          })
        }
      })
      let anim = ui::animation_controller(ctx, 1200, curve: ui::AnimationCurve::ease_in_out)
      mut s = initial_state()
      s.anim = maybe::some(anim)
      s
    },
    build: fn(ctx: ui::BuildContext, state: ui::State<DemoState>) ui::Widget {
      let model = state.value()
      let theme = ui::must_have_theme(ctx)
      let inner = ui::padding(1, ui::column([
        build_header(model.page, model, state, theme),
        ui::sized_box(80, 1, ui::text("")),
        ui::padding(1, build_page(model, state, theme)),
        ui::sized_box(80, 1, ui::text("")),
        build_footer(model.page),
      ]))
      let content = ui::decorated_box(inner, fg: theme.foreground, bg: theme.background)

      let body = ui::shortcuts(
        ui::actions(ui::focus(content), [
          ui::action(demo_quit(), fn(ctx: ui::EventContext, intent: Str) ui::EventResult {
            ui::quit(ctx)
            ui::EventResult::handled
          }),
          ui::action(demo_next(), fn(ctx: ui::EventContext, intent: Str) ui::EventResult {
            go_to_page(model, state, (model.page + 1) % page_count())
            ui::EventResult::handled
          }),
          ui::action(demo_prev(), fn(ctx: ui::EventContext, intent: Str) ui::EventResult {
            go_to_page(model, state, (model.page + page_count() - 1) % page_count())
            ui::EventResult::handled
          }),
          ui::action(demo_dialog(), fn(ctx: ui::EventContext, intent: Str) ui::EventResult {
            state.set(fn(mut s: DemoState) { s.dialog_open = not s.dialog_open })
            ui::EventResult::handled
          }),
          ui::action(demo_palette(), fn(ctx: ui::EventContext, intent: Str) ui::EventResult {
            state.set(fn(mut s: DemoState) { s.palette_open = true })
            ui::EventResult::handled
          }),
        ]),
        keyboard_shortcuts(),
      )

      // Stack overlays in the same order upstream does: palette first,
      // then dialog. ui::overlay collapses to the body when entries is
      // empty.
      mut entries: [ui::OverlayEntry] = []
      if model.palette_open {
        let palette = ui::command_palette(
          items: build_palette_items(model, state),
          on_dismiss: fn(ctx: ui::EventContext) {
            state.set(fn(mut s: DemoState) { s.palette_open = false })
          },
        )
        entries.push(ui::overlay_entry(palette, true, 0, 0))
      }
      if model.dialog_open {
        let dialog_content = ui::dialog(
          "Demo dialog",
          ui::text(
            "Focus stays inside this dialog. Press Escape or choose Close to dismiss it.",
            soft_wrap: true,
          ),
          [
            ui::button("Notify", fn(ctx: ui::EventContext) {
              ui::notify(ctx, "Dialog", "Action from dialog")
            }),
            ui::button("Close", fn(ctx: ui::EventContext) {
              state.set(fn(mut s: DemoState) { s.dialog_open = false })
            }),
          ],
          48,
          fn(ctx: ui::EventContext) {
            state.set(fn(mut s: DemoState) { s.dialog_open = false })
          },
        )
        entries.push(ui::overlay_entry(dialog_content, true, 0, 0))
      }
      ui::overlay(body, entries)
    },
  )
}

// ─── Entrypoint ───────────────────────────────────────────────────────

fn main() Void {
  ui::run_with_theme_set(root_widget(), ui::default_theme_set())
}
