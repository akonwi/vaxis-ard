// ─── Lists page ───────────────────────────────────────────────────────

fn list_demo_row(theme: ui::Theme, i: Int) ui::Widget {
  mut status = "ready"
  mut color = theme.muted_foreground
  if (i % 9) == 0 {
    status = "blocked"
    color = theme.danger_text
  } else if (i % 5) == 0 {
    status = "running"
    color = theme.success_text
  } else if (i % 4) == 0 {
    status = "queued"
    color = theme.warning_text
  }
  ui::rich_text([
    ui::span(pad_left(i.to_str(), 4), attrs: ui::TextAttrs{bold: true}),
    ui::span("  "),
    ui::span("deploy target " + (100 + i).to_str()),
    ui::span("  "),
    ui::span(status, fg: color),
  ])
}

fn chat_demo_message(theme: ui::Theme, i: Int, body: Str) ui::Widget {
  ui::rich_text(
    [
      ui::span(pad_left((i + 1).to_str(), 3), fg: theme.muted_foreground),
      ui::span(" "),
      ui::span(body),
    ],
    soft_wrap: true,
  )
}

// list.push() can't be called on a list captured from an enclosing
// scope, so build the new logs list in a free function (see AGENTS.md).
fn append_logs(logs: [Str], message: Str) [Str] {
  mut next = logs
  next.push("You: " + message)
  next.push("Echo: " + message)
  next
}

fn lists_page(model: DemoState, state: ui::State<DemoState>, theme: ui::Theme) ui::Widget {
  let logs = model.logs
  ui::column([
    ui::rich_text(
      [
        ui::span("Lists", attrs: ui::TextAttrs{bold: true}),
        ui::span("  mixed slivers, lazy rows, and follow-output logs"),
      ],
      soft_wrap: true,
    ),
    ui::sized_box(0, 1, ui::text("")),
    ui::sized_box(72, 5, ui::column([
      ui::list_tile(
        title: ui::text("Deploy queue"),
        leading: ui::text("•"),
        subtitle: ui::text("2 running, 4 queued"),
        trailing: ui::text("open"),
        selected: true,
        on_pressed: fn(ctx: ui::EventContext) {
          ui::notify(ctx, "List tile", "Deploy queue")
        },
      ),
      ui::list_tile(
        title: ui::text("Checks passing"),
        leading: ui::styled_text("✓", fg: theme.success_text),
        trailing: ui::text("12/12"),
        on_pressed: fn(ctx: ui::EventContext) {
          ui::notify(ctx, "List tile", "Checks passing")
        },
      ),
      ui::list_tile(
        title: ui::text("Archived target"),
        leading: ui::text("·"),
        subtitle: ui::text("disabled row"),
        disabled: true,
      ),
    ])),
    ui::sized_box(0, 1, ui::text("")),
    ui::sized_box(72, 3, ui::scrollbar(
      ui::custom_scroll_view(
        ui::scroll_controller(),
        [
          ui::sliver_to_box(ui::text(
            "The intro sliver scrolls away before the pinned header takes over.",
            soft_wrap: true,
          )),
          ui::sliver_pinned_header(ui::decorated_box(
            ui::text(" #  target             status"),
            fg: theme.foreground,
            bg: theme.surface,
            attrs: ui::TextAttrs{bold: true},
          )),
          ui::sliver_list_builder(
            count: 2000,
            item_extent: 1,
            overscan: 12,
            builder: fn(ctx: ui::BuildContext, i: Int) ui::Widget {
              list_demo_row(theme, i + 1)
            },
          ),
          ui::sliver_to_box(ui::rich_text(
            [
              ui::span("Footer sliver", attrs: ui::TextAttrs{bold: true}),
              ui::span("\nTrack clicks page the same viewport as Page Up and Page Down. Drag the thumb for proportional scrolling."),
            ],
            soft_wrap: true,
          )),
        ],
      ),
    )),
    ui::sized_box(0, 1, ui::text("")),
    ui::text_field(
      value: model.chat,
      placeholder: "echo a message",
      min_width: 72,
      on_changed: fn(ctx: ui::EventContext, value: Str) {
        state.set(fn(mut s: DemoState) { s.chat = value })
      },
      on_submitted: fn(ctx: ui::EventContext, value: Str) {
        let trimmed = value.trim()
        if not (trimmed == "") {
          state.set(fn(mut s: DemoState) {
            s.logs = append_logs(s.logs, trimmed)
            s.chat = ""
          })
        }
      },
    ),
    ui::sized_box(0, 1, ui::text("")),
    ui::styled_text("Variable-height messages", -1, -1, attrs: ui::TextAttrs{bold: true}),
    ui::sized_box(72, 2, ui::scrollbar(
      ui::custom_scroll_view(
        ui::scroll_controller(),
        [
          ui::sliver_list_builder(
            count: logs.size(),
            estimated_item_extent: 2,
            overscan: 8,
            builder: fn(ctx: ui::BuildContext, i: Int) ui::Widget {
              chat_demo_message(theme, i, logs.at(i))
            },
          ),
        ],
        follow_output: true,
      ),
    )),
  ])
}

