use vaxis
use vaxis/ui
use ard/async
use ard/duration
use ard/maybe

// ─── Domain ───────────────────────────────────────────────────────────

struct DemoState {
  page: Int,
  name: Str,
  notes: Str,
  count: Int,
  ticks: Int,
  done: Bool,
  mode: Str,
  dialog_open: Bool,
  palette_open: Bool,
  chat: Str,
  logs: [Str],
  anim: ui::AnimationController?,
}

fn initial_state() DemoState {
  DemoState{
    page: 0, name: "", notes: "", count: 0, ticks: 0,
    done: false, mode: "compact", dialog_open: false, palette_open: false,
    chat: "",
    logs: [
      "Ada: welcome to the echo log",
      "Linus: submit a message below",
      "Grace: the viewport follows while you are at the end",
    ],
  }
}

fn page_count() Int { 7 }
fn animation_page_index() Int { 5 }
fn demo_quit() Str { "demo.quit" }
fn demo_next() Str { "demo.next-page" }
fn demo_prev() Str { "demo.previous-page" }
fn demo_dialog() Str { "demo.toggle-dialog" }
fn demo_palette() Str { "demo.command-palette" }

fn checkbox_label(checked: Bool) Str {
  if checked { "checked" } else { "unchecked" }
}

fn pad_left(s: Str, width: Int) Str {
  mut result = s
  while result.size() < width {
    result = " " + result
  }
  result
}

fn pad_right(s: Str, width: Int) Str {
  mut result = s
  while result.size() < width {
    result = result + " "
  }
  result
}

// ─── Home page ────────────────────────────────────────────────────────

fn home_page(ticks: Int) ui::Widget {
  ui::column(
    [
      ui::rich_text(
        [
          ui::span("Home", attrs: ui::TextAttrs{bold: true}),
          ui::span("\nThis example is intentionally larger than the counter. It uses state, focus, buttons, shortcuts, rich text, wrapping text, alignment, themed borders, and runtime dispatch from a goroutine."),
        ],
        soft_wrap: true,
      ),
      ui::sized_box(80, 1, ui::text("")),
      ui::text(
        "The ticker below is updated through BuildContext.Runtime().Dispatch, then SetState marks this widget dirty.",
        soft_wrap: true,
      ),
      ui::rich_text(
        [
          ui::span("ticks: "),
          ui::span(ticks.to_str(), attrs: ui::TextAttrs{bold: true}),
        ],
        soft_wrap: false,
      ),
    ],
    cross_align: ui::CrossAlign::start,
  )
}

// ─── Text page ────────────────────────────────────────────────────────

fn scroll_demo_lines() ui::Widget {
  mut lines: [ui::Widget] = []
  mut i = 1
  while i <= 24 {
    lines.push(ui::rich_text(
      [
        ui::span("row " + i.to_str(), attrs: ui::TextAttrs{bold: true}),
        ui::span("  scrollable content for the demo viewport"),
      ],
      soft_wrap: false,
    ))
    i = i + 1
  }
  ui::column(lines, cross_align: ui::CrossAlign::start)
}

fn horizontal_scroll_line() Str {
  "col-001 alpha  |  col-002 beta  |  col-003 gamma  |  col-004 delta  |  col-005 epsilon  |  col-006 zeta  |  col-007 eta"
}

fn scroll_pane_demo_text() Str {
  mut out = ""
  mut row = 1
  while row <= 18 {
    if row > 1 { out = out + "\n" }
    mut col = 1
    while col <= 10 {
      if col > 1 { out = out + "  " }
      out = out + "r" + pad_left(row.to_str(), 2) + "c" + pad_left(col.to_str(), 2)
      col = col + 1
    }
    row = row + 1
  }
  out
}

