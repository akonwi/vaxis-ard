// ─── Animation page ───────────────────────────────────────────────────

fn animation_status_text(status: ui::AnimationStatus) Str {
  match status {
    ui::AnimationStatus::forward   => "running",
    ui::AnimationStatus::completed => "complete",
    ui::AnimationStatus::idle      => "idle",
  }
}

fn animation_track(value: Float, width: Int) Str {
  if width <= 1 { "◆" }
  else {
    mut pos = ui::float_to_int(value * Float::from_int(width - 1))
    if pos < 0 { pos = 0 }
    if pos >= width { pos = width - 1 }
    mut out = "|"
    mut i = 0
    while i < pos {
      out = out + " "
      i = i + 1
    }
    out = out + "◆"
    mut j = pos + 1
    while j < width - 1 {
      out = out + " "
      j = j + 1
    }
    out + "|"
  }
}

fn animation_page(model: DemoState, theme: ui::Theme) ui::Widget {
  let ctrl = model.anim.expect("animation controller created in init")
  let value = ui::anim_value(ctrl)
  let status = animation_status_text(ui::anim_status(ctrl))
  ui::column(
    [
      ui::rich_text(
        [
          ui::span("Animation", attrs: ui::TextAttrs{bold: true}),
          ui::span("\nThis page uses a StateBase-owned AnimationController. The runner ticks it before each frame and the state is rebuilt while it is active."),
        ],
        soft_wrap: true,
      ),
      ui::sized_box(0, 1, ui::text("")),
      ui::rich_text([
        ui::span("value: "),
        ui::span(value.to_str(), attrs: ui::TextAttrs{bold: true}),
        ui::span("   status: "),
        ui::span(status, attrs: ui::TextAttrs{bold: true}),
      ]),
      ui::constrained_box(
        ui::text(animation_track(value, 120), overflow: ui::TextOverflow::clip),
        max_w: 120,
      ),
      ui::constrained_box(
        ui::progress_bar(
          value,
          width: 120,
          gradient_start: theme.accent,
          gradient_end: theme.primary_hovered,
        ),
        max_w: 120,
      ),
      ui::sized_box(0, 1, ui::text("")),
      ui::row(
        [
          ui::button("Replay", fn(ctx: ui::EventContext) { ui::anim_forward(ctrl) }),
          ui::sized_box(1, 1, ui::text("")),
          ui::button("Stop", fn(ctx: ui::EventContext) { ui::anim_stop(ctrl) }),
          ui::sized_box(1, 1, ui::text("")),
          ui::button("Reset", fn(ctx: ui::EventContext) { ui::anim_reset(ctrl) }),
        ],
        cross_align: ui::CrossAlign::center,
      ),
    ],
    cross_align: ui::CrossAlign::start,
  )
}

// ─── Theme page ───────────────────────────────────────────────────────

fn theme_swatch_span(name: Str, bg: Int, fg: Int) ui::TextSpan {
  ui::span(" " + pad_right(name, 24) + " ", fg: fg, bg: bg)
}

fn theme_text_span(name: Str, fg: Int) ui::TextSpan {
  ui::span(" " + pad_right(name, 24) + " ", fg: fg)
}

fn theme_swatch_row(spans: [ui::TextSpan]) ui::Widget {
  mut row: [ui::TextSpan] = [ui::span("    ")]
  mut i = 0
  while i < spans.size() {
    if i > 0 { row.push(ui::span("  ")) }
    row.push(spans.at(i))
    i = i + 1
  }
  ui::rich_text(row)
}

fn theme_group(name: Str, children: [ui::Widget]) ui::Widget {
  mut group: [ui::Widget] = [ui::rich_text([ui::span("  "), ui::span(name, attrs: ui::TextAttrs{bold: true})])]
  mut i = 0
  while i < children.size() {
    group.push(children.at(i))
    i = i + 1
  }
  ui::column(group, cross_align: ui::CrossAlign::start)
}

fn palette_scale(name: Str, tones: [Int]) ui::Widget {
  mut spans: [ui::TextSpan] = [ui::span(pad_right(name, 9))]
  mut i = 0
  while i < tones.size() {
    spans.push(ui::span("  ", bg: tones.at(i)))
    i = i + 1
  }
  ui::rich_text(spans)
}

