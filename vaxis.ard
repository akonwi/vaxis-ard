// ─── Pure Ard Types ────────────────────────────────────────────────────

// ── Color (type union) ─────────────────────────────────────────────────

struct DefaultColor {}

struct IndexedColor {
  value: Int,
}

struct RGBColor {
  r: Int,
  g: Int,
  b: Int,
}

type Color = DefaultColor | IndexedColor | RGBColor

let COLOR_DEFAULT: Color = DefaultColor{}
let COLOR_BLACK: Color = IndexedColor{ value: 0 }
let COLOR_RED: Color = IndexedColor{ value: 1 }
let COLOR_GREEN: Color = IndexedColor{ value: 2 }
let COLOR_YELLOW: Color = IndexedColor{ value: 3 }
let COLOR_BLUE: Color = IndexedColor{ value: 4 }
let COLOR_MAGENTA: Color = IndexedColor{ value: 5 }
let COLOR_CYAN: Color = IndexedColor{ value: 6 }
let COLOR_WHITE: Color = IndexedColor{ value: 7 }

fn rgb(r: Int, g: Int, b: Int) Color {
  RGBColor{ r: r, g: g, b: b }
}

fn indexed(i: Int) Color {
  IndexedColor{ value: i }
}

// ── UnderlineStyle ─────────────────────────────────────────────────────

enum UnderlineStyle {
  off,
  single,
  double,
  curly,
  dotted,
  dashed,
}

// ── Style ──────────────────────────────────────────────────────────────

struct Style {
  fg: Color,
  bg: Color,
  ul_color: Color,
  ul_style: UnderlineStyle,
  bold: Bool,
  dim: Bool,
  italic: Bool,
  blink: Bool,
  reverse: Bool,
  invisible: Bool,
  strikethrough: Bool,
}

// ── Character & Cell ───────────────────────────────────────────────────

struct Character {
  grapheme: Str,
  width: Int,
}

struct Cell {
  character: Character,
  style: Style,
}

// ── Key ────────────────────────────────────────────────────────────────

let KEY_UP = "up"
let KEY_DOWN = "down"
let KEY_LEFT = "left"
let KEY_RIGHT = "right"
let KEY_SELECT = "select"
let KEY_BACKSPACE = "backspace"
let KEY_REDRAW = "redraw"
let KEY_QUIT = "q"

// ── Events ─────────────────────────────────────────────────────────────

struct KeyEvent {
  key: Str,
  modifiers: Int,
  event_type: Int,
}

// Modifier bitmask (matching vaxis Go ModifierMask)
let MOD_SHIFT = 1
let MOD_ALT = 2
let MOD_CTRL = 4
let MOD_SUPER = 8
let MOD_HYPER = 16
let MOD_META = 32
let MOD_CAPS_LOCK = 64
let MOD_NUM_LOCK = 128

// EventType (matching vaxis Go EventType)
let EVENT_PRESS = 0
let EVENT_REPEAT = 1
let EVENT_RELEASE = 2
let EVENT_MOTION = 3
let EVENT_PASTE = 4

struct ResizeEvent {
  cols: Int,
  rows: Int,
}

struct FocusInEvent {}

struct FocusOutEvent {}

struct PasteStartEvent {}

struct PasteEndEvent {}

struct RedrawEvent {}

struct QuitEvent {}

struct ColorThemeEvent {
  dark: Bool,
}

struct MouseEvent {
  button: Int,
  col: Int,
  row: Int,
  modifiers: Int,
  event_type: Int,
}

type Event = KeyEvent | ResizeEvent | FocusInEvent | FocusOutEvent | PasteStartEvent | PasteEndEvent | RedrawEvent | QuitEvent | ColorThemeEvent | MouseEvent

// ── MouseShape ────────────────────────────────────────────────────────

let MOUSE_SHAPE_DEFAULT = "default"
let MOUSE_SHAPE_TEXT = "text"
let MOUSE_SHAPE_POINTER = "pointer"
let MOUSE_SHAPE_HELP = "help"
let MOUSE_SHAPE_PROGRESS = "progress"
let MOUSE_SHAPE_WAIT = "wait"
let MOUSE_SHAPE_EW_RESIZE = "ew-resize"
let MOUSE_SHAPE_NS_RESIZE = "ns-resize"
let MOUSE_SHAPE_CELL = "cell"

// ── MouseButton ───────────────────────────────────────────────────────

let MOUSE_LEFT = 0
let MOUSE_MIDDLE = 1
let MOUSE_RIGHT = 2
let MOUSE_NONE = 3
let MOUSE_WHEEL_UP = 64
let MOUSE_WHEEL_DOWN = 65
let MOUSE_BACKWARD = 128
let MOUSE_FORWARD = 129

// ── CursorStyle ───────────────────────────────────────────────────────

enum CursorStyle {
  default,
  block_blinking,
  block,
  underline_blinking,
  underline,
  beam_blinking,
  beam,
}

impl CursorStyle {
  // workaround for FFI
  fn to_int() Int {
    match self {
      CursorStyle::default => 0,
      CursorStyle::block_blinking => 1,
      CursorStyle::block => 2,
      CursorStyle::underline_blinking => 3,
      CursorStyle::underline => 4,
      CursorStyle::beam_blinking => 5,
      CursorStyle::beam => 6,
    }
  }
}

// ─── Helpers (must be defined before use in impl blocks) ───────────────

fn color_to_int(color: Color) Int {
  match color {
    DefaultColor => -1,
    IndexedColor(it) => it.value,
    RGBColor(it) => it.r * 65536 + it.g * 256 + it.b,
  }
}

fn style_attrs(s: Style) Int {
  mut attrs = 0
  if s.bold { attrs = attrs + 1 }
  if s.dim { attrs = attrs + 2 }
  if s.italic { attrs = attrs + 4 }
  if s.blink { attrs = attrs + 8 }
  if s.reverse { attrs = attrs + 16 }
  if s.invisible { attrs = attrs + 32 }
  if s.strikethrough { attrs = attrs + 64 }
  attrs
}

impl UnderlineStyle {
  fn to_int() Int {
    match self {
      UnderlineStyle::off => 0,
      UnderlineStyle::single => 1,
      UnderlineStyle::double => 2,
      UnderlineStyle::curly => 3,
      UnderlineStyle::dotted => 4,
      UnderlineStyle::dashed => 5,
    }
  }
}

fn parse_event(raw: Str) Event {
  mut event: Event = KeyEvent{ key: raw, modifiers: 0, event_type: 0 }
  if raw == "redraw" { event = RedrawEvent{} }
  if raw == "quit" { event = QuitEvent{} }
  if raw == "focus:in" { event = FocusInEvent{} }
  if raw == "focus:out" { event = FocusOutEvent{} }
  if raw == "paste:start" { event = PasteStartEvent{} }
  if raw == "paste:end" { event = PasteEndEvent{} }
  if raw == "theme:dark" { event = ColorThemeEvent{ dark: true } }
  if raw == "theme:light" { event = ColorThemeEvent{ dark: false } }
  if raw.starts_with("key:") {
    let rest = raw.replace("key:", "")
    let parts = rest.split(":")
    // Format: key:<modmask>:<eventtype>:<name>
    // Backward compat: key:<name>
    mut mods = 0
    mut etype = 0
    mut name = rest
    if parts.size() >= 3 {
      mods = Int::from_str(parts.at(0)).or(0)
      etype = Int::from_str(parts.at(1)).or(0)
      name = parts.at(2)
    }
    event = KeyEvent{ key: name, modifiers: mods, event_type: etype }
  }
  if raw.starts_with("resize:") {
    let split = raw.split(":")
    let cols_str = split.at(1)
    let rows_str = split.at(2)
    let cols = Int::from_str(cols_str).or(80)
    let rows = Int::from_str(rows_str).or(24)
    event = ResizeEvent{ cols: cols, rows: rows }
  }
  if raw.starts_with("mouse:") {
    let rest = raw.replace("mouse:", "")
    let parts = rest.split(":")
    let btn = Int::from_str(parts.at(0)).or(0)
    let col = Int::from_str(parts.at(1)).or(0)
    let row = Int::from_str(parts.at(2)).or(0)
    let mods = Int::from_str(parts.at(3)).or(0)
    let etype = Int::from_str(parts.at(4)).or(0)
    event = MouseEvent{ button: btn, col: col, row: row, modifiers: mods, event_type: etype }
  }
  event
}

// ─── Style constructors and impl ──────────────────────────────────────

fn default_style() Style {
  Style{
    fg: COLOR_DEFAULT,
    bg: COLOR_DEFAULT,
    ul_color: COLOR_DEFAULT,
    ul_style: UnderlineStyle::off,
    bold: false,
    dim: false,
    italic: false,
    blink: false,
    reverse: false,
    invisible: false,
    strikethrough: false,
  }
}

impl Style {
  fn with_fg(c: Color) Style {
    Style{
      fg: c,
      bg: self.bg,
      ul_color: self.ul_color,
      ul_style: self.ul_style,
      bold: self.bold,
      dim: self.dim,
      italic: self.italic,
      blink: self.blink,
      reverse: self.reverse,
      invisible: self.invisible,
      strikethrough: self.strikethrough,
    }
  }

  fn with_bg(c: Color) Style {
    Style{
      fg: self.fg,
      bg: c,
      ul_color: self.ul_color,
      ul_style: self.ul_style,
      bold: self.bold,
      dim: self.dim,
      italic: self.italic,
      blink: self.blink,
      reverse: self.reverse,
      invisible: self.invisible,
      strikethrough: self.strikethrough,
    }
  }

  fn with_bold(v: Bool) Style {
    Style{
      fg: self.fg,
      bg: self.bg,
      ul_color: self.ul_color,
      ul_style: self.ul_style,
      bold: v,
      dim: self.dim,
      italic: self.italic,
      blink: self.blink,
      reverse: self.reverse,
      invisible: self.invisible,
      strikethrough: self.strikethrough,
    }
  }

  fn with_dim(v: Bool) Style {
    Style{
      fg: self.fg,
      bg: self.bg,
      ul_color: self.ul_color,
      ul_style: self.ul_style,
      bold: self.bold,
      dim: v,
      italic: self.italic,
      blink: self.blink,
      reverse: self.reverse,
      invisible: self.invisible,
      strikethrough: self.strikethrough,
    }
  }

  fn with_italic(v: Bool) Style {
    Style{
      fg: self.fg,
      bg: self.bg,
      ul_color: self.ul_color,
      ul_style: self.ul_style,
      bold: self.bold,
      dim: self.dim,
      italic: v,
      blink: self.blink,
      reverse: self.reverse,
      invisible: self.invisible,
      strikethrough: self.strikethrough,
    }
  }

  fn with_underline(v: Bool) Style {
    let ul = match v {
      true => UnderlineStyle::single,
      false => UnderlineStyle::off,
    }
    Style{
      fg: self.fg,
      bg: self.bg,
      ul_color: self.ul_color,
      ul_style: ul,
      bold: self.bold,
      dim: self.dim,
      italic: self.italic,
      blink: self.blink,
      reverse: self.reverse,
      invisible: self.invisible,
      strikethrough: self.strikethrough,
    }
  }

  fn with_reverse(v: Bool) Style {
    Style{
      fg: self.fg,
      bg: self.bg,
      ul_color: self.ul_color,
      ul_style: self.ul_style,
      bold: self.bold,
      dim: self.dim,
      italic: self.italic,
      blink: self.blink,
      reverse: v,
      invisible: self.invisible,
      strikethrough: self.strikethrough,
    }
  }
}

// ─── Cell constructors ────────────────────────────────────────────────

fn default_cell() Cell {
  Cell{
    character: Character{ grapheme: " ", width: 1 },
    style: default_style(),
  }
}

fn cell_from_str(grapheme: Str) Cell {
  Cell{
    character: Character{ grapheme: grapheme, width: 1 },
    style: default_style(),
  }
}

fn cell_styled(grapheme: Str, style: Style) Cell {
  Cell{
    character: Character{ grapheme: grapheme, width: 1 },
    style: style,
  }
}

// ── Segment (text + style pair) ────────────────────────────────────

struct Segment {
  text: Str,
  style: Style,
}

fn seg(text: Str, style: Style) Segment {
  Segment{ text: text, style: style }
}

fn plain_seg(text: Str) Segment {
  Segment{ text: text, style: default_style() }
}

// ─── Window ────────────────────────────────────────────────────────────

struct Window {
  vx: RawVaxis,
  col_offset: Int,
  row_offset: Int,
  width: Int,
  height: Int,
}

fn window_root(vx: RawVaxis, width: Int, height: Int) Window {
  Window{ vx: vx, col_offset: 0, row_offset: 0, width: width, height: height }
}

impl Window {
  fn child(col: Int, row: Int, width: Int, height: Int) Window {
    mut w = width
    if w < 0 { w = self.width - col }
    mut h = height
    if h < 0 { h = self.height - row }
    Window{
      vx: self.vx,
      col_offset: self.col_offset + col,
      row_offset: self.row_offset + row,
      width: w,
      height: h,
    }
  }

  fn width() Int { self.width }

  fn height() Int { self.height }

  fn mut set_cell(col: Int, row: Int, cell: Cell) {
    let in_bounds = col >= 0 and col < self.width and row >= 0 and row < self.height
    if in_bounds {
      let s = cell.style
      _raw_set_cell(
        self.vx,
        self.col_offset + col,
        self.row_offset + row,
        cell.character.grapheme,
        cell.character.width,
        color_to_int(s.fg),
        color_to_int(s.bg),
        color_to_int(s.ul_color),
        s.ul_style.to_int(),
        style_attrs(s),
      )
    }
  }

  fn mut fill(cell: Cell) {
    let s = cell.style
    let attrs = style_attrs(s)
    let ul = s.ul_style.to_int()
    _raw_fill_region(
      self.vx,
      self.col_offset,
      self.row_offset,
      self.width,
      self.height,
      cell.character.grapheme,
      color_to_int(s.fg),
      color_to_int(s.bg),
      color_to_int(s.ul_color),
      ul,
      attrs,
    )
  }

  fn mut clear() {
    _raw_clear_region(self.vx, self.col_offset, self.row_offset, self.width, self.height)
  }

  fn mut show_cursor(col: Int, row: Int) {
    _raw_show_cursor(self.vx, self.col_offset + col, self.row_offset + row)
  }

  fn mut show_cursor_styled(col: Int, row: Int, style: CursorStyle) {
    _raw_show_cursor_styled(self.vx, self.col_offset + col, self.row_offset + row, style.to_int())
  }

  fn mut write(col: Int, row: Int, text: Str, style: Style) {
    _raw_write(
      self.vx,
      self.col_offset + col,
      self.row_offset + row,
      text,
      color_to_int(style.fg),
      color_to_int(style.bg),
      color_to_int(style.ul_color),
      style.ul_style.to_int(),
      style_attrs(style),
    )
  }

  fn mut write_line(row: Int, col: Int, text: Str, style: Style) {
    _raw_write(
      self.vx,
      self.col_offset + col,
      self.row_offset + row,
      text,
      color_to_int(style.fg),
      color_to_int(style.bg),
      color_to_int(style.ul_color),
      style.ul_style.to_int(),
      style_attrs(style),
    )
  }

  fn origin_col() Int { self.col_offset }

  fn origin_row() Int { self.row_offset }

  fn mut set_style(col: Int, row: Int, style: Style) {
    let in_bounds = col >= 0 and col < self.width and row >= 0 and row < self.height
    if in_bounds {
      _raw_set_style(
        self.vx,
        self.col_offset + col,
        self.row_offset + row,
        color_to_int(style.fg),
        color_to_int(style.bg),
        color_to_int(style.ul_color),
        style.ul_style.to_int(),
        style_attrs(style),
      )
    }
  }

  fn mut print(col: Int, row: Int, segs: [Segment]) Int {
    mut texts: [Str] = []
    mut fgs: [Int] = []
    mut bgs: [Int] = []
    mut uls: [Int] = []
    mut ul_styles: [Int] = []
    mut attrss: [Int] = []
    for seg in segs {
      let s = seg.style
      texts.push(seg.text)
      fgs.push(color_to_int(s.fg))
      bgs.push(color_to_int(s.bg))
      uls.push(color_to_int(s.ul_color))
      ul_styles.push(s.ul_style.to_int())
      attrss.push(style_attrs(s))
    }
    let pos = _raw_print(
      self.vx,
      self.col_offset + col,
      self.row_offset + row,
      self.width - col,
      self.height - row,
      texts, fgs, bgs, uls, ul_styles, attrss,
    )
    pos % 10000 - self.col_offset
  }

  fn mut println(row: Int, col: Int, segs: [Segment]) {
    mut texts: [Str] = []
    mut fgs: [Int] = []
    mut bgs: [Int] = []
    mut uls: [Int] = []
    mut ul_styles: [Int] = []
    mut attrss: [Int] = []
    for seg in segs {
      let s = seg.style
      texts.push(seg.text)
      fgs.push(color_to_int(s.fg))
      bgs.push(color_to_int(s.bg))
      uls.push(color_to_int(s.ul_color))
      ul_styles.push(s.ul_style.to_int())
      attrss.push(style_attrs(s))
    }
    _raw_println(
      self.vx,
      self.col_offset + col,
      self.row_offset + row,
      self.width - col,
      texts, fgs, bgs, uls, ul_styles, attrss,
    )
  }

  fn mut print_truncate(row: Int, col: Int, segs: [Segment]) {
    mut texts: [Str] = []
    mut fgs: [Int] = []
    mut bgs: [Int] = []
    mut uls: [Int] = []
    mut ul_styles: [Int] = []
    mut attrss: [Int] = []
    for seg in segs {
      let s = seg.style
      texts.push(seg.text)
      fgs.push(color_to_int(s.fg))
      bgs.push(color_to_int(s.bg))
      uls.push(color_to_int(s.ul_color))
      ul_styles.push(s.ul_style.to_int())
      attrss.push(style_attrs(s))
    }
    _raw_print_truncate(
      self.vx,
      self.col_offset + col,
      self.row_offset + row,
      self.width - col,
      texts, fgs, bgs, uls, ul_styles, attrss,
    )
  }

  fn mut wrap(col: Int, row: Int, segs: [Segment]) Int {
    mut texts: [Str] = []
    mut fgs: [Int] = []
    mut bgs: [Int] = []
    mut uls: [Int] = []
    mut ul_styles: [Int] = []
    mut attrss: [Int] = []
    for seg in segs {
      let s = seg.style
      texts.push(seg.text)
      fgs.push(color_to_int(s.fg))
      bgs.push(color_to_int(s.bg))
      uls.push(color_to_int(s.ul_color))
      ul_styles.push(s.ul_style.to_int())
      attrss.push(style_attrs(s))
    }
    let pos = _raw_wrap(
      self.vx,
      self.col_offset + col,
      self.row_offset + row,
      self.width - col,
      self.height - row,
      texts, fgs, bgs, uls, ul_styles, attrss,
    )
    pos % 10000 - self.col_offset
  }
}

// ─── App ───────────────────────────────────────────────────────────────

struct App {
  vx: RawVaxis,
  width: Int,
  height: Int,
}

// ── Options ──────────────────────────────────────────────────────────

struct Options {
  disable_kitty_keyboard: Bool?,
  disable_mouse: Bool?,
  no_signals: Bool?,
  csiu_bit_mask: Int?,
  enable_sgr_pixels: Bool?,
}

fn default_options() Options {
  Options{
    disable_kitty_keyboard: true,
    disable_mouse: false,
    no_signals: false,
    csiu_bit_mask: 1,
    enable_sgr_pixels: false,
  }
}

fn pack_options(opts: Options) Int {
  mut v = 0
  if opts.disable_kitty_keyboard.or(false) { v = v + 1 }
  if opts.disable_mouse.or(false) { v = v + 2 }
  if opts.no_signals.or(false) { v = v + 4 }
  if opts.enable_sgr_pixels.or(false) { v = v + 8 }
  v + (opts.csiu_bit_mask.or(0) * 16)
}

fn app_open(title: Str, opts: Options?) App!Str {
  let opts = opts.or(default_options())
  let vx = try _raw_open_with(title, pack_options(opts))
  Result::ok(App{ vx: vx, width: _raw_width(vx), height: _raw_height(vx) })
}

impl App {
  fn mut close() Void!Str {
    _raw_close(self.vx)
  }

  fn mut suspend() Void!Str {
    _raw_suspend(self.vx)
  }

  fn mut resume() Void!Str {
    _raw_resume(self.vx)
  }

  fn mut render() Void!Str {
    _raw_render(self.vx)
  }

  fn mut refresh() Void {
    _raw_refresh(self.vx)
  }

  fn mut hide_cursor() Void {
    _raw_hide_cursor(self.vx)
  }

  fn mut show_cursor(col: Int, row: Int) Void {
    _raw_show_cursor(self.vx, col, row)
  }

  fn mut show_cursor_styled(col: Int, row: Int, style: CursorStyle) Void {
    _raw_show_cursor_styled(self.vx, col, row, style.to_int())
  }

  fn mut read_key() Str!Str {
    let raw = try _raw_read_key(self.vx)
    mut key = "redraw"
    if raw.starts_with("key:") {
      let rest = raw.replace("key:", "")
      let parts = rest.split(":")
      if parts.size() >= 3 {
        key = parts.at(2)
      } else {
        key = rest
      }
    }
    if raw == "quit" { key = "q" }
    Result::ok(key)
  }

  fn mut read_event() Event!Str {
    let key = try _raw_read_key(self.vx)
    Result::ok(parse_event(key))
  }

  fn root_window() Window {
    window_root(self.vx, self.width, self.height)
  }

  fn window(col: Int, row: Int, width: Int, height: Int) Window {
    let root = window_root(self.vx, self.width, self.height)
    root.child(col, row, width, height)
  }

  fn can_rgb() Bool { _raw_can_rgb(self.vx) }
  fn can_sixel() Bool { _raw_can_sixel(self.vx) }
  fn can_kitty_graphics() Bool { _raw_can_kitty_graphics(self.vx) }
  fn can_unicode_core() Bool { _raw_can_unicode_core(self.vx) }
  fn can_display_graphics() Bool { _raw_can_display_graphics(self.vx) }

  fn mut bell() Void { _raw_bell(self.vx) }
  fn mut set_title(title: Str) Void { _raw_set_title(self.vx, title) }
  fn mut notify(title: Str, body: Str) Void { _raw_notify(self.vx, title, body) }
  fn mut clipboard_push(text: Str) Void { _raw_clipboard_push(self.vx, text) }
  fn rendered_width(text: Str) Int { _raw_rendered_width(self.vx, text) }
  fn terminal_id() Str { _raw_terminal_id(self.vx) }
  fn text_backspace(text: Str) Str { _raw_text_backspace(text) }

  // ── P1: Mouse, clipboard, queries ────────────────────────────────

  fn mut set_mouse_shape(shape: Str) Void { _raw_set_mouse_shape(self.vx, shape) }
  fn mut clipboard_pop() Str!Str { _raw_clipboard_pop(self.vx) }
  fn mut notify_working_directory(path: Str) Void { _raw_notify_working_directory(self.vx, path) }
  fn mut set_app_id(id: Str) Void { _raw_set_app_id(self.vx, id) }
  fn query_color(index: Int) Int { _raw_query_color(self.vx, index) }
  fn query_foreground() Int { _raw_query_foreground(self.vx) }
  fn query_background() Int { _raw_query_background(self.vx) }
  fn can_report_color() Bool { _raw_can_report_color(self.vx) }
  fn can_report_foreground_color() Bool { _raw_can_report_foreground_color(self.vx) }
  fn can_report_background_color() Bool { _raw_can_report_background_color(self.vx) }
  fn can_set_app_id() Bool { _raw_can_set_app_id(self.vx) }
  fn can_explicit_width() Bool { _raw_can_explicit_width(self.vx) }
  fn can_in_band_resize() Bool { _raw_can_in_band_resize(self.vx) }
}
