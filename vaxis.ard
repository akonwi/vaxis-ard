// ─── Raw FFI ──────────────────────────────────────────────────────────
// Thin, minimal Go companion. Only what Ard cannot do:
//   - terminal I/O (raw mode, alt screen)
//   - ANSI parsing & event multiplexing (requires Go select)
//   - ANSI escape writing (diff renderer)
//   - capability queries & signal handling

extern type RawVaxis = "*vaxis.Vaxis"

// ── Lifecycle

extern fn _raw_open(title: Str) RawVaxis!Str = "Open"

extern fn _raw_open_with(title: Str, opts: Int) RawVaxis!Str = "OpenWith"

extern fn _raw_close(vx: RawVaxis) Void!Str = "Close"

extern fn _raw_suspend(vx: RawVaxis) Void!Str = "Suspend"

extern fn _raw_resume(vx: RawVaxis) Void!Str = "Resume"

// ── Render

extern fn _raw_render(vx: RawVaxis) Void!Str = "Render"

extern fn _raw_refresh(vx: RawVaxis) Void = "Refresh"

extern fn _raw_width(vx: RawVaxis) Int = "Width"

extern fn _raw_height(vx: RawVaxis) Int = "Height"

// ── Cell buffer (Go-owned screen buffer)

extern fn _raw_set_cell(
  vx: RawVaxis,
  col: Int,
  row: Int,
  grapheme: Str,
  width: Int,
  fg: Int,
  bg: Int,
  ul_color: Int,
  ul_style: Int,
  attrs: Int,
) Void = "SetCell"

extern fn _raw_clear_region(
  vx: RawVaxis,
  col: Int,
  row: Int,
  width: Int,
  height: Int,
) Void = "Clear"

extern fn _raw_write(
  vx: RawVaxis,
  col: Int,
  row: Int,
  text: Str,
  fg: Int,
  bg: Int,
  ul_color: Int,
  ul_style: Int,
  attrs: Int,
) Void = "Write"

extern fn _raw_fill_region(
  vx: RawVaxis,
  col: Int,
  row: Int,
  width: Int,
  height: Int,
  grapheme: Str,
  fg: Int,
  bg: Int,
  ul_color: Int,
  ul_style: Int,
  attrs: Int,
) Void = "Fill"

// ── Cursor

extern fn _raw_show_cursor(vx: RawVaxis, col: Int, row: Int) Void = "ShowCursor"

extern fn _raw_show_cursor_styled(vx: RawVaxis, col: Int, row: Int, style: Int) Void = "ShowCursorStyled"

extern fn _raw_hide_cursor(vx: RawVaxis) Void = "HideCursor"

// ── Events (Go multiplexes stdin + signals, normalizes to strings)

extern fn _raw_read_key(vx: RawVaxis) Str!Str = "ReadEvent"

