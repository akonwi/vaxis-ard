// ── SegmentedControl ──────────────────────────────────────────────────

extern type SegmentedItem = "ffi.UiSegmentedItem"

extern fn _segmented_control(value: Str, segments: [SegmentedItem], disabled: Bool, on_changed: fn(EventContextHandle, Str)) Widget = "UiSegmentedControl"
extern fn _segmented_item(value: Str, label: Str, disabled: Bool) SegmentedItem = "UiMakeSegmentedItem"

fn segment(value: Str, label: Str) SegmentedItem { _segmented_item(value, label, false) }

fn segmented_control(value: Str, segments: [SegmentedItem], on_changed: fn(EventContext, Str)) Widget {
  _segmented_control(value, segments, false,
    fn(ctx: EventContextHandle, next: Str) { on_changed(EventContext{handle: ctx}, next) })
}

// ── Divider ───────────────────────────────────────────────────────────

extern fn _divider(axis: Int, fg: Int, bg: Int, attrs: Int) Widget = "UiDivider"

// Divider paints a one-cell separator. The default axis is horizontal.
//
// Because Divider writes cells directly without merging with the underlying
// surface style, an unset background paints the terminal default colour. If
// the divider sits inside a themed surface, pass `bg` so the divider blends
// in (commonly `theme.background` or `theme.surface`).
fn divider(axis: Axis?, fg: vaxis::Color?, bg: vaxis::Color?, attrs: TextAttrs?) Widget {
  _divider(
    axis.or(Axis::horizontal).to_int(),
    vaxis::color_to_int(fg.or(vaxis::COLOR_DEFAULT)),
    vaxis::color_to_int(bg.or(vaxis::COLOR_DEFAULT)),
    attrs.or(TextAttrs{}).to_int(),
  )
}

// ── Text input ────────────────────────────────────────────────────────

extern fn _text_field(
  value: Str, placeholder: Str, min_width: Int, obscure: Bool,
  on_changed: fn(EventContextHandle, Str),
  has_on_submitted: Bool, on_submitted: fn(EventContextHandle, Str),
) Widget = "UiTextField"

fn text_field(
  value: Str, on_changed: fn(EventContext, Str)?,
  placeholder: Str?, min_width: Int?, obscure: Bool?, on_submitted: fn(EventContext, Str)?,
) Widget {
  let changed = on_changed.or(fn(_c: EventContext, _s: Str) {})
  let sub = on_submitted.or(fn(_c: EventContext, _s: Str) {})
  _text_field(value, placeholder.or(""), min_width.or(0), obscure.or(false),
    fn(ctx: EventContextHandle, next: Str) { changed(EventContext{handle: ctx}, next) },
    on_submitted.is_some(),
    fn(ctx: EventContextHandle, s: Str) { sub(EventContext{handle: ctx}, s) })
}

// ── TextArea ──────────────────────────────────────────────────────────

extern fn _text_area(value: Str, placeholder: Str, min_width: Int, min_height: Int, soft_wrap: Bool, on_changed: fn(EventContextHandle, Str)) Widget = "UiTextArea"

fn text_area(
  value: Str, on_changed: fn(EventContext, Str),
  placeholder: Str?, min_width: Int?, min_height: Int?, soft_wrap: Bool?,
) Widget {
  _text_area(value, placeholder.or(""), min_width.or(0), min_height.or(0), soft_wrap.or(false),
    fn(ctx: EventContextHandle, next: Str) { on_changed(EventContext{handle: ctx}, next) })
}

// ── Scroll ────────────────────────────────────────────────────────────

enum ScrollAxis { vertical, horizontal }

impl ScrollAxis {
  fn to_int() Int {
    match self {
      ScrollAxis::vertical => 0,
      ScrollAxis::horizontal => 1,
    }
  }
}

extern type ScrollController = "*ui.ScrollController"
extern type ScrollPaneController = "*ui.ScrollPaneController"

extern fn _scroll_controller() ScrollController = "UiScrollController"
extern fn _scroll_view(
  child: Widget, axis: Int, has_controller: Bool, controller: ScrollController,
) Widget = "UiScrollView"
extern fn _scrollbar(child: Widget, axis: Int) Widget = "UiScrollbar"

extern fn _scroll_pane_controller() ScrollPaneController = "UiScrollPaneController"
extern fn _scroll_pane(controller: ScrollPaneController, child: Widget) Widget = "UiScrollPane"
extern fn _scroll_pane_scroll_by(controller: ScrollPaneController, cols: Int, rows: Int) Bool = "UiScrollPaneScrollBy"
extern fn _scroll_pane_scroll_to(controller: ScrollPaneController, col: Int, row: Int) Bool = "UiScrollPaneScrollTo"
extern fn _scroll_pane_metrics(controller: ScrollPaneController, axis: Int) [Int] = "UiScrollPaneMetrics"

// scroll_view lays its child out with bounded cross-axis constraints
// and unbounded main-axis (the scrolling axis). That keeps soft-wrap
// and other width-dependent layout working on the child, unlike
// scroll_pane which unbounds both axes.
//
// Pass a `controller` to drive programmatic scrolling (line scroll,
// scroll to offset, scroll to start/end). Without one a fresh internal
// controller is created on every build, so the scroll position would
// snap back to the top whenever state changes.
fn scroll_view(
  child: Widget, axis: ScrollAxis?, controller: ScrollController?,
) Widget {
  let has_controller = controller.is_some()
  let c = controller.or(_scroll_controller())
  _scroll_view(child, axis.or(ScrollAxis::vertical).to_int(), has_controller, c)
}

fn scrollbar(child: Widget, axis: ScrollAxis?) Widget {
  _scrollbar(child, axis.or(ScrollAxis::vertical).to_int())
}

fn scroll_pane_controller() ScrollPaneController { _scroll_pane_controller() }
fn scroll_pane(child: Widget, controller: ScrollPaneController?) Widget {
  _scroll_pane(controller.or(_scroll_pane_controller()), child)
}
fn scroll_pane_scroll_by(controller: ScrollPaneController, cols: Int, rows: Int) Bool {
  _scroll_pane_scroll_by(controller, cols, rows)
}
fn scroll_pane_scroll_to(controller: ScrollPaneController, col: Int, row: Int) Bool {
  _scroll_pane_scroll_to(controller, col, row)
}

// Reports the current layout state of a mounted scroll pane on the
// chosen axis. Returns a zero-valued ScrollMetrics if the controller
// hasn't been attached to a mounted pane yet (e.g. before the first
// layout pass).
//
// Build-time use case: after the first frame, callers can read this to
// know whether content has been scrolled off either edge — useful for
// overflow chevrons, scrollbar visibility, etc.
struct ScrollMetrics {
  scroll_offset: Int,
  max_scroll_offset: Int,
  viewport_width: Int,
  viewport_height: Int,
  content_width: Int,
  content_height: Int,
}

fn scroll_pane_metrics(
  controller: ScrollPaneController, axis: ScrollAxis?,
) ScrollMetrics {
  let arr = _scroll_pane_metrics(controller, axis.or(ScrollAxis::vertical).to_int())
  ScrollMetrics{
    scroll_offset: arr.at(0),
    max_scroll_offset: arr.at(1),
    viewport_width: arr.at(2),
    viewport_height: arr.at(3),
    content_width: arr.at(4),
    content_height: arr.at(5),
  }
}

// ── CustomScrollView / Slivers ────────────────────────────────────────

extern fn _scroll_controller_scroll_by_lines(c: ScrollController, lines: Int) Bool = "UiScrollControllerScrollByLines"
extern fn _scroll_controller_scroll_to_offset(c: ScrollController, row: Int) Bool = "UiScrollControllerScrollToOffset"
extern fn _scroll_controller_scroll_to_start(c: ScrollController) Bool = "UiScrollControllerScrollToStart"
extern fn _scroll_controller_scroll_to_end(c: ScrollController) Bool = "UiScrollControllerScrollToEnd"

fn scroll_controller() ScrollController { _scroll_controller() }
fn scroll_controller_scroll_by_lines(c: ScrollController, lines: Int) Bool {
  _scroll_controller_scroll_by_lines(c, lines)
}
fn scroll_controller_scroll_to_offset(c: ScrollController, row: Int) Bool {
  _scroll_controller_scroll_to_offset(c, row)
}
fn scroll_controller_scroll_to_start(c: ScrollController) Bool {
  _scroll_controller_scroll_to_start(c)
}
fn scroll_controller_scroll_to_end(c: ScrollController) Bool {
  _scroll_controller_scroll_to_end(c)
}

extern fn _custom_scroll_view(controller: ScrollController, slivers: [Widget], follow_output: Bool) Widget = "UiCustomScrollView"
extern fn _sliver_to_box(child: Widget) Widget = "UiSliverToBox"
extern fn _sliver_pinned_header(child: Widget) Widget = "UiSliverPinnedHeader"
extern fn _sliver_fill_remaining(child: Widget) Widget = "UiSliverFillRemaining"
extern fn _sliver_list(children: [Widget]) Widget = "UiSliverList"
extern fn _sliver_list_builder(
  count: Int, item_extent: Int, estimated_item_extent: Int, overscan: Int,
  builder: fn(BuildContextHandle, Int) Widget,
  has_controller: Bool, controller: SliverListController,
) Widget = "UiSliverListBuilder"

extern type SliverListController = "*ui.SliverListController"
extern fn _sliver_list_controller() SliverListController = "UiSliverListController"
extern fn _sliver_list_controller_reveal_index(
  c: SliverListController, index: Int,
) Bool = "UiSliverListControllerRevealIndex"
extern fn _sliver_list_controller_scroll_to_index(
  c: SliverListController, index: Int, align: Int,
) Bool = "UiSliverListControllerScrollToIndex"
extern fn _scroll_controller_metrics(c: ScrollController) [Int] = "UiScrollControllerMetrics"

fn scroll_controller() ScrollController { _scroll_controller() }
fn scroll_controller_scroll_by_lines(c: ScrollController, lines: Int) Bool { _scroll_controller_scroll_by_lines(c, lines) }
fn scroll_controller_scroll_to_offset(c: ScrollController, row: Int) Bool { _scroll_controller_scroll_to_offset(c, row) }
fn scroll_controller_scroll_to_start(c: ScrollController) Bool { _scroll_controller_scroll_to_start(c) }
fn scroll_controller_scroll_to_end(c: ScrollController) Bool { _scroll_controller_scroll_to_end(c) }

fn custom_scroll_view(controller: ScrollController, slivers: [Widget], follow_output: Bool?) Widget {
  _custom_scroll_view(controller, slivers, follow_output.or(false))
}

fn sliver_to_box(child: Widget) Widget { _sliver_to_box(child) }
fn sliver_pinned_header(child: Widget) Widget { _sliver_pinned_header(child) }
fn sliver_fill_remaining(child: Widget) Widget { _sliver_fill_remaining(child) }
fn sliver_list(children: [Widget]) Widget { _sliver_list(children) }

// `controller` is optional; pass one to drive the list with
// reveal_index / scroll_to_index after it mounts.
fn sliver_list_builder(
  count: Int, builder: fn(BuildContext, Int) Widget,
  item_extent: Int?, estimated_item_extent: Int?, overscan: Int?,
  controller: SliverListController?,
) Widget {
  let has_controller = controller.is_some()
  let c = controller.or(_sliver_list_controller())
  _sliver_list_builder(
    count, item_extent.or(0), estimated_item_extent.or(0), overscan.or(0),
    fn(ctx: BuildContextHandle, i: Int) Widget { builder(BuildContext{handle: ctx}, i) },
    has_controller, c,
  )
}

fn sliver_list_controller() SliverListController { _sliver_list_controller() }

fn sliver_list_controller_reveal_index(
  c: SliverListController, index: Int,
) Bool { _sliver_list_controller_reveal_index(c, index) }

// `align` is one of:
//   0 = start  (top of viewport)
//   1 = center
//   2 = end    (bottom of viewport)
fn sliver_list_controller_scroll_to_index(
  c: SliverListController, index: Int, align: Int,
) Bool { _sliver_list_controller_scroll_to_index(c, index, align) }

fn scroll_controller_metrics(controller: ScrollController) ScrollMetrics {
  let arr = _scroll_controller_metrics(controller)
  ScrollMetrics{
    scroll_offset: arr.at(0),
    max_scroll_offset: arr.at(1),
    viewport_width: arr.at(2),
    viewport_height: arr.at(3),
    content_width: arr.at(4),
    content_height: arr.at(5),
  }
}

// ── Actions ───────────────────────────────────────────────────────────

extern fn _actions(child: Widget, bindings: [ActionBinding]) Widget = "UiActions"
extern fn _shortcuts(child: Widget, bindings: [Str:Str]) Widget = "UiShortcuts"

fn action(name: Str, handler: fn(EventContext, Str) EventResult) ActionBinding {
  _action_binding(name,
    fn(ctx: EventContextHandle, intent: Str) Int {
      match handler(EventContext{handle: ctx}, intent) {
        EventResult::handled => 1,
        EventResult::ignored => 0,
      }
    })
}

fn actions(child: Widget, bindings: [ActionBinding]) Widget { _actions(child, bindings) }
fn shortcuts(child: Widget, bindings: [Str:Str]) Widget { _shortcuts(child, bindings) }

// ── Focus ─────────────────────────────────────────────────────────────

extern fn _focus(child: Widget) Widget = "UiFocus"
extern fn _focus_scope(
  child: Widget, trap: Bool, auto_focus: Bool, reclaim_focus: Bool,
) Widget = "UiFocusScope"

fn focus(child: Widget) Widget { _focus(child) }

// `trap`         keeps Tab traversal inside child while focus is inside.
// `auto_focus`   moves focus to the first descendant focus target on
//                mount when focus is outside the scope.
// `reclaim_focus` re-runs the auto_focus pass on every rebuild whenever
//                 focus is outside the scope. Useful when the focused
//                 element can be disposed mid-life (e.g. the modal's
//                 child swaps from a loading view to a real body) so
//                 focus snaps back into the scope instead of being
//                 lost. Defaults to false to match the previous
//                 behaviour; matches upstream FocusScope.ReclaimFocus.
fn focus_scope(
  child: Widget, trap: Bool, auto_focus: Bool, reclaim_focus: Bool?,
) Widget {
  _focus_scope(child, trap, auto_focus, reclaim_focus.or(false))
}

// ── Stateful widget ───────────────────────────────────────────────────

extern fn _stateful<$T>(
  key: Str, init: fn(BuildContextHandle, StateHandle) $T, build: fn(BuildContextHandle, StateHandle) Widget,
) Widget = "UiStateful"

extern fn _state_value<$T>(ctx: StateHandle) $T = "UiStateValue"
extern fn _state_set_value<$T>(ctx: StateHandle, value: $T) Void = "UiStateSetValue"

extern type RuntimeHandle = "ui.Runtime"
extern fn _build_context_runtime(ctx: BuildContextHandle) RuntimeHandle = "UiBuildContextRuntime"
extern fn _runtime_dispatch(runtime: RuntimeHandle, state: StateHandle, callback: fn(StateHandle)) Void = "UiRuntimeDispatch"

struct BuildContext { handle: BuildContextHandle, state: StateHandle? }

struct State<$T> { handle: StateHandle }

impl State {
  fn value() $T { _state_value<$T>(self.handle) }
  fn set(mutate: fn(mut $T)) {
    mut next = self.value()
    mutate(next)
    _state_set_value(self.handle, next)
  }
}

struct Runtime<$T> { handle: RuntimeHandle, state: StateHandle? }

impl Runtime {
  fn dispatch(callback: fn(State<$T>)) {
    match self.state {
      h => _runtime_dispatch(self.handle, h,
        fn(state_handle: StateHandle) { callback(State{handle: state_handle}) }),
      _ => {},
    }
  }
}

impl BuildContext {
  fn runtime<$T>() Runtime<$T> {
    Runtime{handle: _build_context_runtime(self.handle), state: self.state}
  }
}

fn stateful<$T>(
  key: Str, init: fn(BuildContext) $T, build: fn(BuildContext, State<$T>) Widget,
) Widget {
  _stateful(key: key,
    init: fn(build_ctx: BuildContextHandle, state_handle: StateHandle) $T {
      init(BuildContext{handle: build_ctx, state: state_handle})
    },
    build: fn(build_ctx: BuildContextHandle, state_handle: StateHandle) Widget {
      build(BuildContext{handle: build_ctx, state: state_handle}, State{handle: state_handle})
    })
}
