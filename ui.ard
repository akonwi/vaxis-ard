extern fn _actions(child: Widget, bindings: [ActionBinding]) Widget   = "UiActions"
extern fn _shortcuts(child: Widget, bindings: [Str:Str]) Widget   = "UiShortcuts"

fn action(name: Str, handler: fn(EventContext, Str) EventResult) ActionBinding {
  _action_binding(
    name,
    fn(ctx: EventContextHandle, intent: Str) Int {
      match handler(EventContext{handle: ctx}, intent) {
        EventResult::handled => 1,
        EventResult::ignored => 0,
      }
    },
  )
}

fn actions(child: Widget, bindings: [ActionBinding]) Widget {
  _actions(child, bindings)
}

fn shortcuts(child: Widget, bindings: [Str:Str]) Widget {
  _shortcuts(child, bindings)
}

// ── Focus ─────────────────────────────────────────────────────────────

extern fn _focus(child: Widget) Widget   = "UiFocus"
extern fn _focus_scope(child: Widget, trap: Bool, auto_focus: Bool) Widget   = "UiFocusScope"

fn focus(child: Widget) Widget { _focus(child) }

fn focus_scope(child: Widget, trap: Bool, auto_focus: Bool) Widget {
  _focus_scope(child, trap, auto_focus)
}

// ── Stateful widget ───────────────────────────────────────────────────

extern fn _stateful<$T>(
  key: Str,
  init: fn(BuildContextHandle, StateHandle) $T,
  build: fn(BuildContextHandle, StateHandle) Widget,
) Widget   = "UiStateful"

extern fn _state_value<$T>(ctx: StateHandle) $T   = "UiStateValue"
extern fn _state_set_value<$T>(ctx: StateHandle, value: $T) Void   = "UiStateSetValue"

// Runtime is vaxis/ui's UI-thread dispatcher. We type it by `$T` so
// dispatched callbacks get `State<$T>` directly.
extern type RuntimeHandle = "ui.Runtime"
extern fn _build_context_runtime(ctx: BuildContextHandle) RuntimeHandle = "UiBuildContextRuntime"
extern fn _runtime_dispatch(
  runtime: RuntimeHandle,
  state: StateHandle,
  callback: fn(StateHandle),
) Void = "UiRuntimeDispatch"

struct BuildContext {
  handle: BuildContextHandle,
  state: StateHandle?,
}

struct State<$T> {
  handle: StateHandle,
}

impl State {
  fn value() $T {
    _state_value<$T>(self.handle)
  }

  fn set(mutate: fn(mut $T)) {
    mut next = self.value()
    mutate(next)
    _state_set_value(self.handle, next)
  }
}

// Runtime<$T> is a typed re-entry point for background work to update state.
// Get one via `ctx.runtime<$T>()` from inside `stateful`'s `init` or `build`.
struct Runtime<$T> {
  handle: RuntimeHandle,
  state: StateHandle?,
}

impl Runtime {
  // Schedule `callback` on the UI thread. The callback receives the
  // typed `State<$T>` so it can call `.set(...)` directly. If the
  // owning stateful widget has unmounted, the dispatch is a no-op.
  fn dispatch(callback: fn(State<$T>)) {
    match self.state {
      h => _runtime_dispatch(
        self.handle,
        h,
        fn(state_handle: StateHandle) {
          callback(State{handle: state_handle})
        },
      ),
      _ => {},
    }
  }
}

impl BuildContext {
  fn runtime<$T>() Runtime<$T> {
    Runtime{handle: _build_context_runtime(self.handle), state: self.state}
  }
}

fn stateful<$T>(
  key: Str,
  init: fn(BuildContext) $T,
  build: fn(BuildContext, State<$T>) Widget,
) Widget {
  _stateful(
    key: key,
    init: fn(build_ctx: BuildContextHandle, state_handle: StateHandle) $T {
      init(BuildContext{handle: build_ctx, state: state_handle})
    },
    build: fn(build_ctx: BuildContextHandle, state_handle: StateHandle) Widget {
      build(
        BuildContext{handle: build_ctx, state: state_handle},
        State{handle: state_handle},
      )
    },
  )
}
