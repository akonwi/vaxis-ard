extern fn _table_column_fixed(width: Int) TableColumn = "UiTableColumnFixed"
extern fn _table_column_flex(flex: Int) TableColumn = "UiTableColumnFlex"
extern fn _table_row(children: [Widget]) TableRow = "UiTableRowNew"

fn table_column_intrinsic() TableColumn { _table_column_intrinsic() }
fn table_column_fixed(width: Int) TableColumn { _table_column_fixed(width) }
fn table_column_flex(flex: Int) TableColumn { _table_column_flex(flex) }
