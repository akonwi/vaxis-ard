// ─── vaxis/ui bindings ────────────────────────────────────────────────
// Thin Ard wrappers for git.sr.ht/~rockorager/vaxis/ui.

use vaxis/vaxis
use ard/maybe

// ── Opaque handles ────────────────────────────────────────────────────

extern type Widget = "ui.Widget"
extern type BuildContextHandle = "ui.BuildContext"
extern type EventContextHandle = "ui.EventContext"
extern type StateHandle = "any"
extern type ActionBinding = "any"

// ── Event result ──────────────────────────────────────────────────────

enum EventResult { ignored, handled }

// ── Action binding (raw FFI) ──────────────────────────────────────────

extern fn _action_binding(name: Str, handler: fn(EventContextHandle, Str) Int) ActionBinding = "NewUiActionBinding"

// ── Lifecycle ─────────────────────────────────────────────────────────

extern fn _run(root: Widget) Void = "UiRun"
extern fn _run_with_theme_set(root: Widget, ts: ThemeSetHandle) Void = "UiRunWithThemeSet"

// ── Event helpers ─────────────────────────────────────────────────────

extern fn _quit(ctx: EventContextHandle) Void = "UiQuit"
extern fn _notify(ctx: EventContextHandle, title: Str, body: Str) Void = "UiNotify"
extern fn _set_title(ctx: EventContextHandle, title: Str) Void = "UiSetTitle"
extern fn _copy(ctx: EventContextHandle, text: Str) Void = "UiCopy"
extern fn _toggle_profile_overlay(ctx: EventContextHandle) Void = "UiToggleProfileOverlay"

struct EventContext { handle: EventContextHandle }

fn quit(ctx: EventContext) { _quit(ctx.handle) }
fn notify(ctx: EventContext, title: Str, body: Str) { _notify(ctx.handle, title, body) }
fn set_title(ctx: EventContext, title: Str) { _set_title(ctx.handle, title) }
fn copy(ctx: EventContext, text: Str) { _copy(ctx.handle, text) }
fn toggle_profile_overlay(ctx: EventContext) { _toggle_profile_overlay(ctx.handle) }

fn toggle_profile_overlay_intent() Str { "vaxis.toggle-profile-overlay" }

// ── Theme system ──────────────────────────────────────────────────────

extern type ThemeHandle = "ffi.UiTheme"

extern fn _theme_default() ThemeHandle = "UiThemeDefault"
extern fn _theme_light() ThemeHandle = "UiThemeLight"
extern fn _theme_dark() ThemeHandle = "UiThemeDark"
extern fn _must_have_theme(ctx: BuildContextHandle) ThemeHandle = "UiMustHaveTheme"
extern fn _provider_theme(theme: ThemeHandle, child: Widget) Widget = "UiProviderTheme"

// Collapsed read/write: all 22 semantic colors in a single FFI call each.
extern fn _theme_colors(t: ThemeHandle) [Int] = "UiThemeColors"
extern fn _theme_set_colors(t: ThemeHandle, colors: [Int]) ThemeHandle = "UiThemeSetColors"
extern fn _theme_mode(t: ThemeHandle) Int = "UiThemeModeGet"
extern fn _theme_set_mode(t: ThemeHandle, mode: Int) ThemeHandle = "UiThemeModeSet"

extern fn _theme_palette_scale(t: ThemeHandle, family: Int) [Int] = "UiThemePaletteScale"

enum PaletteFamily {
  neutral,
  red,
  green,
  yellow,
  blue,
  magenta,
  cyan,
}

impl PaletteFamily {
  fn to_int() Int {
    match self {
      PaletteFamily::neutral => 0,
      PaletteFamily::red => 1,
      PaletteFamily::green => 2,
      PaletteFamily::yellow => 3,
      PaletteFamily::blue => 4,
      PaletteFamily::magenta => 5,
      PaletteFamily::cyan => 6,
    }
  }
}

enum ThemeMode { dark, light }

impl ThemeMode {
  fn to_int() Int {
    match self {
      ThemeMode::dark => 0,
      ThemeMode::light => 1,
    }
  }
}

fn theme_mode_from_int(v: Int) ThemeMode {
  if v == 1 { ThemeMode::light }
  else { ThemeMode::dark }
}

struct Palette {
  neutral: [Int],
  red: [Int],
  green: [Int],
  yellow: [Int],
  blue: [Int],
  magenta: [Int],
  cyan: [Int],
}

struct Theme {
  background: vaxis::Color,
  foreground: vaxis::Color,
  surface: vaxis::Color,
  surface_raised: vaxis::Color,
  surface_hovered: vaxis::Color,
  surface_pressed: vaxis::Color,
  primary: vaxis::Color,
  primary_text: vaxis::Color,
  primary_hovered: vaxis::Color,
  primary_pressed: vaxis::Color,
  accent: vaxis::Color,
  accent_text: vaxis::Color,
  success: vaxis::Color,
  success_text: vaxis::Color,
  warning: vaxis::Color,
  warning_text: vaxis::Color,
  danger: vaxis::Color,
  danger_text: vaxis::Color,
  muted_foreground: vaxis::Color,
  disabled_foreground: vaxis::Color,
  selection: vaxis::Color,
  border: vaxis::Color,
  mode: ThemeMode,
  palette: Palette,
}

fn _theme_from_handle(h: ThemeHandle) Theme {
  let colors = _theme_colors(h)
  let palette = Palette{
    neutral: _theme_palette_scale(h, PaletteFamily::neutral.to_int()),
    red:     _theme_palette_scale(h, PaletteFamily::red.to_int()),
    green:   _theme_palette_scale(h, PaletteFamily::green.to_int()),
    yellow:  _theme_palette_scale(h, PaletteFamily::yellow.to_int()),
    blue:    _theme_palette_scale(h, PaletteFamily::blue.to_int()),
    magenta: _theme_palette_scale(h, PaletteFamily::magenta.to_int()),
    cyan:    _theme_palette_scale(h, PaletteFamily::cyan.to_int()),
  }
  Theme{
    background: vaxis::int_to_color(colors.at(0)),
    foreground: vaxis::int_to_color(colors.at(1)),
    surface: vaxis::int_to_color(colors.at(2)),
    surface_raised: vaxis::int_to_color(colors.at(3)),
    surface_hovered: vaxis::int_to_color(colors.at(4)),
    surface_pressed: vaxis::int_to_color(colors.at(5)),
    primary: vaxis::int_to_color(colors.at(6)),
    primary_text: vaxis::int_to_color(colors.at(7)),
    primary_hovered: vaxis::int_to_color(colors.at(8)),
    primary_pressed: vaxis::int_to_color(colors.at(9)),
    accent: vaxis::int_to_color(colors.at(10)),
    accent_text: vaxis::int_to_color(colors.at(11)),
    success: vaxis::int_to_color(colors.at(12)),
    success_text: vaxis::int_to_color(colors.at(13)),
    warning: vaxis::int_to_color(colors.at(14)),
    warning_text: vaxis::int_to_color(colors.at(15)),
    danger: vaxis::int_to_color(colors.at(16)),
    danger_text: vaxis::int_to_color(colors.at(17)),
    muted_foreground: vaxis::int_to_color(colors.at(18)),
    disabled_foreground: vaxis::int_to_color(colors.at(19)),
    selection: vaxis::int_to_color(colors.at(20)),
    border: vaxis::int_to_color(colors.at(21)),
    mode: theme_mode_from_int(_theme_mode(h)),
    palette: palette,
  }
}

fn _theme_to_handle(theme: Theme) ThemeHandle {
  mut h = _theme_default()
  let colors = [
    vaxis::color_to_int(theme.background),
    vaxis::color_to_int(theme.foreground),
    vaxis::color_to_int(theme.surface),
    vaxis::color_to_int(theme.surface_raised),
    vaxis::color_to_int(theme.surface_hovered),
    vaxis::color_to_int(theme.surface_pressed),
    vaxis::color_to_int(theme.primary),
    vaxis::color_to_int(theme.primary_text),
    vaxis::color_to_int(theme.primary_hovered),
    vaxis::color_to_int(theme.primary_pressed),
    vaxis::color_to_int(theme.accent),
    vaxis::color_to_int(theme.accent_text),
    vaxis::color_to_int(theme.success),
    vaxis::color_to_int(theme.success_text),
    vaxis::color_to_int(theme.warning),
    vaxis::color_to_int(theme.warning_text),
    vaxis::color_to_int(theme.danger),
    vaxis::color_to_int(theme.danger_text),
    vaxis::color_to_int(theme.muted_foreground),
    vaxis::color_to_int(theme.disabled_foreground),
    vaxis::color_to_int(theme.selection),
    vaxis::color_to_int(theme.border),
  ]
  h = _theme_set_colors(h, colors)
  _theme_set_mode(h, theme.mode.to_int())
}

fn theme_default() Theme { _theme_from_handle(_theme_default()) }
fn theme_light() Theme { _theme_from_handle(_theme_light()) }
fn theme_dark() Theme { _theme_from_handle(_theme_dark()) }
fn must_have_theme(ctx: BuildContext) Theme { _theme_from_handle(_must_have_theme(ctx.handle)) }
fn provider_theme(theme: Theme, child: Widget) Widget { _provider_theme(_theme_to_handle(theme), child) }

extern type ThemeSetHandle = "ffi.UiThemeSet"
extern fn _default_theme_set() ThemeSetHandle = "UiThemeSetDefault"
extern fn _theme_set_make(light: ThemeHandle, dark: ThemeHandle) ThemeSetHandle = "UiThemeSetMake"

struct ThemeSet {
  handle: ThemeSetHandle,
}

fn default_theme_set() ThemeSet {
  ThemeSet{ handle: _default_theme_set() }
}

// Build a custom ThemeSet from explicit light and dark themes.
// Useful when you want to override what the terminal reports —
// e.g. passing `dark` for BOTH slots forces the dark theme
// regardless of `ColorThemeUpdate` events from the terminal.
fn theme_set(light: Theme, dark: Theme) ThemeSet {
  ThemeSet{
    handle: _theme_set_make(_theme_to_handle(light), _theme_to_handle(dark)),
  }
}

fn run(root: Widget, theme_set: ThemeSet?) {
  match theme_set {
    t => _run_with_theme_set(root, t.handle),
    _ => _run(root),
  }
}

// ── Layout widgets ────────────────────────────────────────────────────

extern fn _center(child: Widget) Widget = "UiCenter"
extern fn _padding(top: Int, right: Int, bottom: Int, left: Int, child: Widget) Widget = "UiPadding"
extern fn _expanded(child: Widget) Widget = "UiExpanded"
extern fn _flexible(flex: Int, child: Widget) Widget = "UiFlexible"
extern fn _sized_box(width: Int, height: Int, child: Widget) Widget = "UiSizedBox"

fn center(child: Widget) Widget { _center(child) }
// Wraps `child` with padding cells on each side.
//
// Precedence (most specific wins):
//   per-side (top/right/bottom/left)
//   axis (horizontal/vertical)
//   uniform (all)
//   0
//
// Examples:
//   ui::padding(child, all: 1)                       // 1 on every side
//   ui::padding(child, horizontal: 2)                // 2 left/right only
//   ui::padding(child, vertical: 1, horizontal: 2)   // 1 top/bottom, 2 sides
//   ui::padding(child, all: 1, top: 0)               // 1 right/bottom/left, 0 top
fn padding(
  child: Widget,
  all: Int?, horizontal: Int?, vertical: Int?,
  top: Int?, right: Int?, bottom: Int?, left: Int?,
) Widget {
  let a = all.or(0)
  let h = horizontal.or(a)
  let v = vertical.or(a)
  _padding(top.or(v), right.or(h), bottom.or(v), left.or(h), child)
}
fn expanded(child: Widget) Widget { _expanded(child) }
fn flexible(flex: Int, child: Widget) Widget { _flexible(flex, child) }
fn sized_box(width: Int, height: Int, child: Widget) Widget { _sized_box(width, height, child) }

// ── Flex ──────────────────────────────────────────────────────────────

enum Axis { horizontal, vertical }
enum MainSize { max, min }
enum MainAlign { start, end, center, between, around, evenly }
enum CrossAlign { center, start, end, stretch }

impl Axis {
  fn to_int() Int {
    match self {
      Axis::horizontal => 0,
      Axis::vertical => 1,
    }
  }
}

impl MainSize {
  fn to_int() Int {
    match self {
      MainSize::max => 0,
      MainSize::min => 1,
    }
  }
}

impl MainAlign {
  fn to_int() Int {
    match self {
      MainAlign::start => 0, MainAlign::end => 1,
      MainAlign::center => 2, MainAlign::between => 3,
      MainAlign::around => 4, MainAlign::evenly => 5,
    }
  }
}

impl CrossAlign {
  fn to_int() Int {
    match self {
      CrossAlign::center => 0, CrossAlign::start => 1,
      CrossAlign::end => 2, CrossAlign::stretch => 3,
    }
  }
}

extern fn _flex(axis: Int, main_size: Int, main_align: Int, cross_align: Int, children: [Widget]) Widget = "UiFlex"

fn row(
  children: [Widget], main_align: MainAlign?, cross_align: CrossAlign?, main_size: MainSize?,
) Widget {
  _flex(Axis::horizontal.to_int(), main_size.or(MainSize::max).to_int(),
    main_align.or(MainAlign::start).to_int(), cross_align.or(CrossAlign::center).to_int(), children)
}

fn column(
  children: [Widget], main_align: MainAlign?, cross_align: CrossAlign?, main_size: MainSize?,
) Widget {
  _flex(Axis::vertical.to_int(), main_size.or(MainSize::max).to_int(),
    main_align.or(MainAlign::start).to_int(), cross_align.or(CrossAlign::stretch).to_int(), children)
}

fn flex(
  axis: Axis, children: [Widget], main_align: MainAlign?, cross_align: CrossAlign?, main_size: MainSize?,
) Widget {
  _flex(axis.to_int(), main_size.or(MainSize::max).to_int(),
    main_align.or(MainAlign::start).to_int(), cross_align.or(CrossAlign::center).to_int(), children)
}

// ── Positioned ────────────────────────────────────────────────────────

extern fn _positioned(left: Int, top: Int, child: Widget) Widget = "UiPositioned"

fn positioned(left: Int, top: Int, child: Widget) Widget { _positioned(left, top, child) }

// ── Borders ───────────────────────────────────────────────────────────

struct Borders {
  top: Bool?,
  right: Bool?,
  bottom: Bool?,
  left: Bool?,
}

fn borders_all() Borders {
  Borders{ top: true, right: true, bottom: true, left: true }
}

fn _border_top(b: Borders?) Bool { b.or(Borders{}).top.or(false) }
fn _border_right(b: Borders?) Bool { b.or(Borders{}).right.or(false) }
fn _border_bottom(b: Borders?) Bool { b.or(Borders{}).bottom.or(false) }
fn _border_left(b: Borders?) Bool { b.or(Borders{}).left.or(false) }

// ── DecoratedBox ──────────────────────────────────────────────────────

extern fn _decorated_box(
  fg: Int, bg: Int, ul_color: Int, ul_style: Int, attrs: Int,
  border_top: Bool, border_right: Bool, border_bottom: Bool, border_left: Bool,
  border_fg: Int, border_bg: Int, border_attrs: Int,
  child: Widget,
) Widget = "UiDecoratedBox"

struct TextAttrs {
  bold: Bool?, dim: Bool?, italic: Bool?, blink: Bool?,
  reverse: Bool?, invisible: Bool?, strikethrough: Bool?,
}

enum TextAttrFlag { bold, dim, italic, blink, reverse, invisible, strikethrough }

impl TextAttrFlag {
  fn to_int() Int {
    match self {
      TextAttrFlag::bold => 1, TextAttrFlag::dim => 2,
      TextAttrFlag::italic => 4, TextAttrFlag::blink => 8,
      TextAttrFlag::reverse => 16, TextAttrFlag::invisible => 32,
      TextAttrFlag::strikethrough => 64,
    }
  }
}

impl TextAttrs {
  fn to_int() Int {
    mut bits = 0
    if self.bold.or(false) { bits = bits + TextAttrFlag::bold.to_int() }
    if self.dim.or(false) { bits = bits + TextAttrFlag::dim.to_int() }
    if self.italic.or(false) { bits = bits + TextAttrFlag::italic.to_int() }
    if self.blink.or(false) { bits = bits + TextAttrFlag::blink.to_int() }
    if self.reverse.or(false) { bits = bits + TextAttrFlag::reverse.to_int() }
    if self.invisible.or(false) { bits = bits + TextAttrFlag::invisible.to_int() }
    if self.strikethrough.or(false) { bits = bits + TextAttrFlag::strikethrough.to_int() }
    bits
  }
}

// Wraps `child` with a fill style and optional border.
//
// Fill style is `fg` / `bg` / `attrs`. Border style defaults to the same
// values; pass `border_fg` / `border_bg` / `border_attrs` to override.
// Border lines paint via DrawCell (no style merge with the underlying
// surface), so an unset `border_bg` paints the terminal default — if
// the box sits inside a themed surface, pass `border_bg` (commonly
// `theme.background` or `theme.surface`) so the border blends in.
fn decorated_box(
  child: Widget,
  fg: vaxis::Color?,
  bg: vaxis::Color?,
  attrs: TextAttrs?,
  border: Borders?,
  border_fg: vaxis::Color?,
  border_bg: vaxis::Color?,
  border_attrs: TextAttrs?,
) Widget {
  _decorated_box(
    vaxis::color_to_int(fg.or(vaxis::COLOR_DEFAULT)),
    vaxis::color_to_int(bg.or(vaxis::COLOR_DEFAULT)),
    -1, 0, attrs.or(TextAttrs{}).to_int(),
    _border_top(border), _border_right(border), _border_bottom(border), _border_left(border),
    vaxis::color_to_int(border_fg.or(fg.or(vaxis::COLOR_DEFAULT))),
    vaxis::color_to_int(border_bg.or(bg.or(vaxis::COLOR_DEFAULT))),
    border_attrs.or(attrs.or(TextAttrs{})).to_int(),
    child,
  )
}

fn bordered_box(
  child: Widget,
  fg: vaxis::Color?,
  bg: vaxis::Color?,
  attrs: TextAttrs?,
) Widget {
  decorated_box(child, fg, bg, attrs, borders_all())
}

// ── Align ─────────────────────────────────────────────────────────────

enum Alignment {
  top_left, top_center, top_right,
  center_left, center, center_right,
  bottom_left, bottom_center, bottom_right,
}

impl Alignment {
  fn to_x() Int {
    match self {
      Alignment::top_left => -1, Alignment::top_center => 0, Alignment::top_right => 1,
      Alignment::center_left => -1, Alignment::center => 0, Alignment::center_right => 1,
      Alignment::bottom_left => -1, Alignment::bottom_center => 0, Alignment::bottom_right => 1,
    }
  }
  fn to_y() Int {
    match self {
      Alignment::top_left => -1, Alignment::top_center => -1, Alignment::top_right => -1,
      Alignment::center_left => 0, Alignment::center => 0, Alignment::center_right => 0,
      Alignment::bottom_left => 1, Alignment::bottom_center => 1, Alignment::bottom_right => 1,
    }
  }
}

extern fn _align(child: Widget, x: Int, y: Int) Widget = "UiAlign"

fn align(child: Widget, alignment: Alignment?) Widget {
  let a = alignment.or(Alignment::center)
  _align(child, a.to_x(), a.to_y())
}

// ── ConstrainedBox ────────────────────────────────────────────────────

extern fn _constrained_box(child: Widget, min_w: Int, max_w: Int, min_h: Int, max_h: Int) Widget = "UiConstrainedBox"

fn constrained_box(child: Widget, min_w: Int?, max_w: Int?, min_h: Int?, max_h: Int?) Widget {
  _constrained_box(child, min_w.or(0), max_w.or(0), min_h.or(0), max_h.or(0))
}

// ── Stack ─────────────────────────────────────────────────────────────

extern fn _stack(children: [Widget], x: Int, y: Int) Widget = "UiStack"
extern fn _indexed_stack(index: Int, children: [Widget], x: Int, y: Int) Widget = "UiIndexedStack"

fn stack(children: [Widget], alignment: Alignment?) Widget {
  let a = alignment.or(Alignment::center)
  _stack(children, a.to_x(), a.to_y())
}

// IndexedStack keeps every child mounted but only paints/hit-tests
// `children[index]`. Useful for tab containers where each tab body has
// state (cursor position, fetched data, scroll offset) that should
// survive switching between tabs.
//
// The stack sizes to the maximum child size; all children are laid out
// with the same loose constraints, then only the visible one paints.
fn indexed_stack(index: Int, children: [Widget], alignment: Alignment?) Widget {
  let a = alignment.or(Alignment::center)
  _indexed_stack(index, children, a.to_x(), a.to_y())
}

// ── Dialog ────────────────────────────────────────────────────────────

extern fn _dialog(title: Str, child: Widget, actions: [Widget], width: Int, on_dismiss: fn(EventContextHandle)) Widget = "UiDialog"

fn dialog(title: Str, child: Widget, actions: [Widget], width: Int, on_dismiss: fn(EventContext)) Widget {
  _dialog(title, child, actions, width,
    fn(ctx: EventContextHandle) { on_dismiss(EventContext{handle: ctx}) })
}

// ── ModalBarrier ──────────────────────────────────────────────────────

extern fn _modal_barrier(fg: Int, bg: Int, ul_color: Int, ul_style: Int, attrs: Int, opacity: Int) Widget = "UiModalBarrier"

fn modal_barrier(bg: vaxis::Color, opacity: Int) Widget {
  _modal_barrier(-1, vaxis::color_to_int(bg), -1, 0, 0, opacity)
}

// ── ListTile ──────────────────────────────────────────────────────────

extern fn _list_tile(
  title: Widget, selected: Bool, disabled: Bool,
  has_leading: Bool, leading: Widget,
  has_subtitle: Bool, subtitle: Widget,
  has_trailing: Bool, trailing: Widget,
  has_on_pressed: Bool, on_pressed: fn(EventContextHandle),
) Widget = "UiListTile"

fn list_tile(
  title: Widget, leading: Widget?, subtitle: Widget?, trailing: Widget?,
  selected: Bool?, disabled: Bool?, on_pressed: fn(EventContext)?,
) Widget {
  let filler = title
  let p = on_pressed.or(fn(_c: EventContext) {})
  _list_tile(title, selected.or(false), disabled.or(false),
    leading.is_some(), leading.or(filler),
    subtitle.is_some(), subtitle.or(filler),
    trailing.is_some(), trailing.or(filler),
    on_pressed.is_some(),
    fn(ctx: EventContextHandle) { p(EventContext{handle: ctx}) })
}

// ── Overlay ───────────────────────────────────────────────────────────

extern type OverlayEntry = "ffi.UiOverlayEntry"

extern fn _overlay(child: Widget, entries: [OverlayEntry]) Widget = "UiOverlay"
extern fn _overlay_entry(child: Widget, modal: Bool, align_x: Int, align_y: Int) OverlayEntry = "UiMakeOverlayEntry"

fn overlay_entry(child: Widget, modal: Bool, align_x: Int, align_y: Int) OverlayEntry {
  _overlay_entry(child, modal, align_x, align_y)
}

fn overlay(child: Widget, entries: [OverlayEntry]) Widget { _overlay(child, entries) }

fn overlay_modal(child: Widget, modal_child: Widget) Widget {
  _overlay(child, [_overlay_entry(modal_child, true, 0, 0)])
}

// ── Selection ─────────────────────────────────────────────────────────

extern fn _selection_area(child: Widget) Widget = "UiSelectionArea"
extern fn _selection_container(child: Widget, disabled: Bool) Widget = "UiSelectionContainer"

fn selection_area(child: Widget) Widget { _selection_area(child) }
fn selection_container(child: Widget, disabled: Bool?) Widget {
  mut d = false
  match disabled {
    v => {
      d = v
    },
    _ => {},
  }
  _selection_container(child, d)
}

// ── CommandPalette ────────────────────────────────────────────────────

extern type CmdItem = "ffi.UiCommandPaletteItem"

extern fn _command_palette(
  items: [CmdItem], placeholder: Str, empty_text: Str, width: Int, max_visible_rows: Int,
  has_on_dismiss: Bool, on_dismiss: fn(EventContextHandle),
  has_on_selected: Bool, on_selected: fn(EventContextHandle, Str),
) Widget = "UiCommandPalette"
extern fn _cmd_item(title: Str, description: Str, aliases: [Str], has_on_selected: Bool, on_selected: fn(EventContextHandle)) CmdItem = "UiMakeCmdItem"

fn cmd_item(
  title: Str, description: Str?, aliases: [Str]?, on_selected: fn(EventContext)?,
) CmdItem {
  let cb = on_selected.or(fn(_c: EventContext) {})
  _cmd_item(title, description.or(""), aliases.or([]), on_selected.is_some(),
    fn(ctx: EventContextHandle) { cb(EventContext{handle: ctx}) })
}

fn command_palette(
  items: [CmdItem], placeholder: Str?, empty_text: Str?, width: Int?, max_visible_rows: Int?,
  on_dismiss: fn(EventContext)?, on_selected: fn(EventContext, Str)?,
) Widget {
  let dc = on_dismiss.or(fn(_c: EventContext) {})
  let sc = on_selected.or(fn(_c: EventContext, _t: Str) {})
  _command_palette(items, placeholder.or(""), empty_text.or(""), width.or(0), max_visible_rows.or(0),
    on_dismiss.is_some(), fn(ctx: EventContextHandle) { dc(EventContext{handle: ctx}) },
    on_selected.is_some(), fn(ctx: EventContextHandle, title: Str) { sc(EventContext{handle: ctx}, title) })
}

// ── Table ─────────────────────────────────────────────────────────────

extern type TableColumn = "ffi.UiTableColumn"
extern type TableRow = "ffi.UiTableRow"

extern fn _table(columns: [TableColumn], column_gap: Int, row_gap: Int, rows: [TableRow]) Widget = "UiTable"
extern fn _table_column_intrinsic() TableColumn = "UiTableColumnIntrinsic"
extern fn _table_column_fixed(width: Int) TableColumn = "UiTableColumnFixed"
extern fn _table_column_flex(flex: Int) TableColumn = "UiTableColumnFlex"
extern fn _table_row(children: [Widget]) TableRow = "UiTableRowNew"

fn table_column_intrinsic() TableColumn { _table_column_intrinsic() }
fn table_column_fixed(width: Int) TableColumn { _table_column_fixed(width) }
fn table_column_flex(flex: Int) TableColumn { _table_column_flex(flex) }
fn table_row(children: [Widget]) TableRow { _table_row(children) }

