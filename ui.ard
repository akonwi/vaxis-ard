let CURSOR_DEFAULT = 0
let CURSOR_BLOCK_BLINKING = 1
let CURSOR_BLOCK = 2
let CURSOR_UNDERLINE_BLINKING = 3
let CURSOR_UNDERLINE = 4
let CURSOR_BEAM_BLINKING = 5
let CURSOR_BEAM = 6

