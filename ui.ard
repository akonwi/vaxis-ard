// ─── vaxis/ui bindings ────────────────────────────────────────────────
// Thin Ard wrappers for git.sr.ht/~rockorager/vaxis/ui.
//
// Each widget constructor delegates to a Go FFI function in ffi/ui.go.
// Closures are wrapped so Ard callbacks receive typed structs instead of
// raw handles.

// ── Opaque handles ────────────────────────────────────────────────────

extern type Widget = "ui.Widget"
extern type BuildContextHandle = "ui.BuildContext"
extern type EventContextHandle = "ui.EventContext"
extern type StateHandle = "any"

// ── Event result ──────────────────────────────────────────────────────

enum EventResult {
  ignored,
  handled,
}

// ── Action binding (raw FFI) ──────────────────────────────────────────

extern type ActionBinding = "any"

extern fn _action_binding(name: Str, handler: fn(EventContextHandle, Str) Int) ActionBinding   = "NewUiActionBinding"

// ── Lifecycle ─────────────────────────────────────────────────────────

extern fn _run(root: Widget) Void!Str   = "UiRun"
extern fn _run_themed(root: Widget, black: Int, red: Int, green: Int, yellow: Int, blue: Int, magenta: Int, cyan: Int, white: Int) Void!Str   = "UiRunWithBaseColors"

fn run(root: Widget) Void!Str {
  _run(root)
}

fn run_themed(root: Widget, black: Int, red: Int, green: Int, yellow: Int, blue: Int, magenta: Int, cyan: Int, white: Int) Void!Str {
  _run_themed(root, black, red, green, yellow, blue, magenta, cyan, white)
}

// ── Event helpers ─────────────────────────────────────────────────────

extern fn _quit(ctx: EventContextHandle) Void   = "UiQuit"
extern fn _notify(ctx: EventContextHandle, title: Str, body: Str) Void   = "UiNotify"
extern fn _set_title(ctx: EventContextHandle, title: Str) Void   = "UiSetTitle"
extern fn _copy(ctx: EventContextHandle, text: Str) Void   = "UiCopy"

struct EventContext {
  handle: EventContextHandle,
}

fn quit(ctx: EventContext) { _quit(ctx.handle) }
fn notify(ctx: EventContext, title: Str, body: Str) { _notify(ctx.handle, title, body) }
fn set_title(ctx: EventContext, title: Str) { _set_title(ctx.handle, title) }
fn copy(ctx: EventContext, text: Str) { _copy(ctx.handle, text) }

// ── Theme system ──────────────────────────────────────────────────────

// Theme mirrors the semantic colors from vaxis/ui.Theme.
// Use theme_default() to get the built-in dark theme, then mutate fields.
struct Theme {
  background: Int,
  foreground: Int,
  surface: Int,
  surface_raised: Int,
  surface_hovered: Int,
  surface_pressed: Int,
  primary: Int,
  primary_text: Int,
  primary_hovered: Int,
  primary_pressed: Int,
  accent: Int,
  accent_text: Int,
  success: Int,
  success_text: Int,
  warning: Int,
  warning_text: Int,
  danger: Int,
  danger_text: Int,
  muted_foreground: Int,
  disabled_foreground: Int,
  selection: Int,
  border: Int,
  mode: Int,
}

// Private Go FFI — used only to read/write the Go Theme struct.
extern type ThemeHandle = "ffi.UiTheme"

extern fn _theme_default() ThemeHandle = "UiThemeDefault"
extern fn _theme_with_background(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithBackground"
extern fn _theme_with_foreground(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithForeground"
extern fn _theme_with_surface(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithSurface"
extern fn _theme_with_surface_raised(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithSurfaceRaised"
extern fn _theme_with_surface_hovered(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithSurfaceHovered"
extern fn _theme_with_surface_pressed(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithSurfacePressed"
extern fn _theme_with_primary(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithPrimary"
extern fn _theme_with_primary_text(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithPrimaryText"
extern fn _theme_with_primary_hovered(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithPrimaryHovered"
extern fn _theme_with_primary_pressed(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithPrimaryPressed"
extern fn _theme_with_accent(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithAccent"
extern fn _theme_with_accent_text(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithAccentText"
extern fn _theme_with_success(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithSuccess"
extern fn _theme_with_success_text(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithSuccessText"
extern fn _theme_with_warning(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithWarning"
extern fn _theme_with_warning_text(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithWarningText"
extern fn _theme_with_danger(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithDanger"
extern fn _theme_with_danger_text(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithDangerText"
extern fn _theme_with_muted_foreground(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithMutedForeground"
extern fn _theme_with_disabled_foreground(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithDisabledForeground"
extern fn _theme_with_selection(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithSelection"
extern fn _theme_with_border(t: ThemeHandle, color: Int) ThemeHandle = "UiThemeWithBorder"
extern fn _theme_with_mode(t: ThemeHandle, mode: Int) ThemeHandle = "UiThemeWithMode"
extern fn _theme_background(t: ThemeHandle) Int = "UiThemeBackground"
extern fn _theme_foreground(t: ThemeHandle) Int = "UiThemeForeground"
extern fn _theme_surface(t: ThemeHandle) Int = "UiThemeSurface"
extern fn _theme_surface_raised(t: ThemeHandle) Int = "UiThemeSurfaceRaised"
extern fn _theme_surface_hovered(t: ThemeHandle) Int = "UiThemeSurfaceHovered"
extern fn _theme_surface_pressed(t: ThemeHandle) Int = "UiThemeSurfacePressed"
extern fn _theme_primary(t: ThemeHandle) Int = "UiThemePrimary"
extern fn _theme_primary_text(t: ThemeHandle) Int = "UiThemePrimaryText"
extern fn _theme_primary_hovered(t: ThemeHandle) Int = "UiThemePrimaryHovered"
extern fn _theme_primary_pressed(t: ThemeHandle) Int = "UiThemePrimaryPressed"
extern fn _theme_accent(t: ThemeHandle) Int = "UiThemeAccent"
extern fn _theme_accent_text(t: ThemeHandle) Int = "UiThemeAccentText"
extern fn _theme_success(t: ThemeHandle) Int = "UiThemeSuccess"
extern fn _theme_success_text(t: ThemeHandle) Int = "UiThemeSuccessText"
extern fn _theme_warning(t: ThemeHandle) Int = "UiThemeWarning"
extern fn _theme_warning_text(t: ThemeHandle) Int = "UiThemeWarningText"
extern fn _theme_danger(t: ThemeHandle) Int = "UiThemeDanger"
extern fn _theme_danger_text(t: ThemeHandle) Int = "UiThemeDangerText"
extern fn _theme_muted_foreground(t: ThemeHandle) Int = "UiThemeMutedForeground"
extern fn _theme_disabled_foreground(t: ThemeHandle) Int = "UiThemeDisabledForeground"
extern fn _theme_selection(t: ThemeHandle) Int = "UiThemeSelection"
extern fn _theme_border(t: ThemeHandle) Int = "UiThemeBorder"
extern fn _theme_mode(t: ThemeHandle) Int = "UiThemeMode"
extern fn _theme_light() ThemeHandle = "UiThemeLight"
extern fn _theme_dark() ThemeHandle = "UiThemeDark"
extern fn _must_have_theme(ctx: BuildContextHandle) ThemeHandle = "UiMustHaveTheme"
extern fn _provider_theme(theme: ThemeHandle, child: Widget) Widget = "UiProviderTheme"
extern fn _run_with_theme(root: Widget, theme: ThemeHandle) Void = "UiRunWithTheme"

// Read a Go ThemeHandle into an Ard Theme struct.
fn _theme_from_handle(h: ThemeHandle) Theme {
  Theme{
    background: _theme_background(h),
    foreground: _theme_foreground(h),
    surface: _theme_surface(h),
    surface_raised: _theme_surface_raised(h),
    surface_hovered: _theme_surface_hovered(h),
    surface_pressed: _theme_surface_pressed(h),
    primary: _theme_primary(h),
    primary_text: _theme_primary_text(h),
    primary_hovered: _theme_primary_hovered(h),
    primary_pressed: _theme_primary_pressed(h),
    accent: _theme_accent(h),
    accent_text: _theme_accent_text(h),
    success: _theme_success(h),
    success_text: _theme_success_text(h),
    warning: _theme_warning(h),
    warning_text: _theme_warning_text(h),
    danger: _theme_danger(h),
    danger_text: _theme_danger_text(h),
    muted_foreground: _theme_muted_foreground(h),
    disabled_foreground: _theme_disabled_foreground(h),
    selection: _theme_selection(h),
    border: _theme_border(h),
    mode: _theme_mode(h),
  }
}

// Write an Ard Theme struct back to a Go ThemeHandle.
fn _theme_to_handle(theme: Theme) ThemeHandle {
  mut h = _theme_default()
  h = _theme_with_background(h, theme.background)
  h = _theme_with_foreground(h, theme.foreground)
  h = _theme_with_surface(h, theme.surface)
  h = _theme_with_surface_raised(h, theme.surface_raised)
  h = _theme_with_surface_hovered(h, theme.surface_hovered)
  h = _theme_with_surface_pressed(h, theme.surface_pressed)
  h = _theme_with_primary(h, theme.primary)
  h = _theme_with_primary_text(h, theme.primary_text)
  h = _theme_with_primary_hovered(h, theme.primary_hovered)
  h = _theme_with_primary_pressed(h, theme.primary_pressed)
  h = _theme_with_accent(h, theme.accent)
  h = _theme_with_accent_text(h, theme.accent_text)
  h = _theme_with_success(h, theme.success)
  h = _theme_with_success_text(h, theme.success_text)
  h = _theme_with_warning(h, theme.warning)
  h = _theme_with_warning_text(h, theme.warning_text)
  h = _theme_with_danger(h, theme.danger)
  h = _theme_with_danger_text(h, theme.danger_text)
  h = _theme_with_muted_foreground(h, theme.muted_foreground)
  h = _theme_with_disabled_foreground(h, theme.disabled_foreground)
  h = _theme_with_selection(h, theme.selection)
  h = _theme_with_border(h, theme.border)
  h = _theme_with_mode(h, theme.mode)
  h
}

fn theme_default() Theme {
  _theme_from_handle(_theme_default())
}

fn theme_light() Theme {
  _theme_from_handle(_theme_light())
}

fn theme_dark() Theme {
  _theme_from_handle(_theme_dark())
}

fn must_have_theme(ctx: BuildContext) Theme {
  _theme_from_handle(_must_have_theme(ctx.handle))
}

fn provider_theme(theme: Theme, child: Widget) Widget {
  _provider_theme(_theme_to_handle(theme), child)
}

fn run_with_theme(root: Widget, theme: Theme) Void!Str {
  Result::ok(_run_with_theme(root, _theme_to_handle(theme)))
}

fn build_theme(
  background: Int?,
  foreground: Int?,
  surface: Int?,
  surface_raised: Int?,
  surface_hovered: Int?,
  surface_pressed: Int?,
  primary: Int?,
  primary_text: Int?,
  primary_hovered: Int?,
  primary_pressed: Int?,
  accent: Int?,
  accent_text: Int?,
  success: Int?,
  success_text: Int?,
  warning: Int?,
  warning_text: Int?,
  danger: Int?,
  danger_text: Int?,
  muted_foreground: Int?,
  disabled_foreground: Int?,
  selection: Int?,
  border: Int?,
  mode: Int?,
) Theme {
  mut theme = theme_default()
  if background.is_some() { theme.background = background }
  if foreground.is_some() { theme.foreground = foreground }
  if surface.is_some() { theme.surface = surface }
  if surface_raised.is_some() { theme.surface_raised = surface_raised }
  if surface_hovered.is_some() { theme.surface_hovered = surface_hovered }
  if surface_pressed.is_some() { theme.surface_pressed = surface_pressed }
  if primary.is_some() { theme.primary = primary }
  if primary_text.is_some() { theme.primary_text = primary_text }
  if primary_hovered.is_some() { theme.primary_hovered = primary_hovered }
  if primary_pressed.is_some() { theme.primary_pressed = primary_pressed }
  if accent.is_some() { theme.accent = accent }
  if accent_text.is_some() { theme.accent_text = accent_text }
  if success.is_some() { theme.success = success }
  if success_text.is_some() { theme.success_text = success_text }
  if warning.is_some() { theme.warning = warning }
  if warning_text.is_some() { theme.warning_text = warning_text }
  if danger.is_some() { theme.danger = danger }
  if danger_text.is_some() { theme.danger_text = danger_text }
  if muted_foreground.is_some() { theme.muted_foreground = muted_foreground }
  if disabled_foreground.is_some() { theme.disabled_foreground = disabled_foreground }
  if selection.is_some() { theme.selection = selection }
  if border.is_some() { theme.border = border }
  if mode.is_some() { theme.mode = mode }
  theme
}

// ── Layout widgets ────────────────────────────────────────────────────

extern fn _center(child: Widget) Widget   = "UiCenter"
extern fn _padding(all: Int, child: Widget) Widget   = "UiPadding"
extern fn _expanded(child: Widget) Widget   = "UiExpanded"
extern fn _flexible(flex: Int, child: Widget) Widget = "UiFlexible"
extern fn _sized_box(width: Int, height: Int, child: Widget) Widget   = "UiSizedBox"

fn center(child: Widget) Widget { _center(child) }
fn padding(all: Int, child: Widget) Widget { _padding(all, child) }
fn expanded(child: Widget) Widget { _expanded(child) }
fn flexible(flex: Int, child: Widget) Widget { _flexible(flex, child) }
fn sized_box(width: Int, height: Int, child: Widget) Widget { _sized_box(width, height, child) }

// ── Flex ──────────────────────────────────────────────────────────────
//
// row / column / flex take optional layout knobs as typed enums.
// Defaults match vaxis zero values, except `column` defaults to
// CrossAlign::stretch (TUI columns almost always want stretched children).

enum Axis {
  horizontal,
  vertical,
}

enum MainSize {
  max,
  min,
}

enum MainAlign {
  start,
  end,
  center,
  between,
  around,
  evenly,
}

enum CrossAlign {
  center,
  start,
  end,
  stretch,
}

impl Axis {
  fn to_int() Int {
    match self {
      Axis::horizontal => 0,
      Axis::vertical => 1,
    }
  }
}

impl MainSize {
  fn to_int() Int {
    match self {
      MainSize::max => 0,
      MainSize::min => 1,
    }
  }
}

impl MainAlign {
  fn to_int() Int {
    match self {
      MainAlign::start => 0,
      MainAlign::end => 1,
      MainAlign::center => 2,
      MainAlign::between => 3,
      MainAlign::around => 4,
      MainAlign::evenly => 5,
    }
  }
}

impl CrossAlign {
  fn to_int() Int {
    match self {
      CrossAlign::center => 0,
      CrossAlign::start => 1,
      CrossAlign::end => 2,
      CrossAlign::stretch => 3,
    }
  }
}

extern fn _flex(axis: Int, main_size: Int, main_align: Int, cross_align: Int, children: [Widget]) Widget = "UiFlex"

fn row(
  children: [Widget],
  main_align: MainAlign?,
  cross_align: CrossAlign?,
  main_size: MainSize?,
) Widget {
  _flex(
    Axis::horizontal.to_int(),
    main_size.or(MainSize::max).to_int(),
    main_align.or(MainAlign::start).to_int(),
    cross_align.or(CrossAlign::center).to_int(),
    children,
  )
}

fn column(
  children: [Widget],
  main_align: MainAlign?,
  cross_align: CrossAlign?,
  main_size: MainSize?,
) Widget {
  _flex(
    Axis::vertical.to_int(),
    main_size.or(MainSize::max).to_int(),
    main_align.or(MainAlign::start).to_int(),
    cross_align.or(CrossAlign::stretch).to_int(),
    children,
  )
}

fn flex(
  axis: Axis,
  children: [Widget],
  main_align: MainAlign?,
  cross_align: CrossAlign?,
  main_size: MainSize?,
) Widget {
  _flex(
    axis.to_int(),
    main_size.or(MainSize::max).to_int(),
    main_align.or(MainAlign::start).to_int(),
    cross_align.or(CrossAlign::center).to_int(),
    children,
  )
}

// ── Positioned ────────────────────────────────────────────────────────

extern fn _positioned(left: Int, top: Int, child: Widget) Widget = "UiPositioned"

fn positioned(left: Int, top: Int, child: Widget) Widget {
  _positioned(left, top, child)
}

// ── DecoratedBox ──────────────────────────────────────────────────────

extern fn _decorated_box(
  fg: Int, bg: Int, ul_color: Int, ul_style: Int, attrs: Int,
  border_top: Bool, border_right: Bool, border_bottom: Bool, border_left: Bool,
  child: Widget,
) Widget = "UiDecoratedBox"

fn decorated_box(fg: Int, bg: Int, attrs: Int, child: Widget) Widget {
  _decorated_box(fg, bg, -1, 0, attrs, false, false, false, false, child)
}

fn bordered_box(fg: Int, bg: Int, attrs: Int, child: Widget) Widget {
  _decorated_box(fg, bg, -1, 0, attrs, true, true, true, true, child)
}

// ── Align ─────────────────────────────────────────────────────────────

extern fn _align(child: Widget, x: Int, y: Int) Widget = "UiAlign"

fn align(child: Widget, x: Int, y: Int) Widget { _align(child, x, y) }

// ── ConstrainedBox ────────────────────────────────────────────────────

extern fn _constrained_box(min_w: Int, max_w: Int, min_h: Int, max_h: Int, child: Widget) Widget = "UiConstrainedBox"

fn constrained_box(min_w: Int, max_w: Int, min_h: Int, max_h: Int, child: Widget) Widget {
  _constrained_box(min_w, max_w, min_h, max_h, child)
}

// ── Stack ─────────────────────────────────────────────────────────────

extern fn _stack(children: [Widget], x: Int, y: Int) Widget = "UiStack"

fn stack(children: [Widget], x: Int, y: Int) Widget { _stack(children, x, y) }

// ── Dialog ────────────────────────────────────────────────────────────

extern fn _dialog(title: Str, child: Widget, actions: [Widget], width: Int, on_dismiss: fn(EventContextHandle)) Widget = "UiDialog"

fn dialog(title: Str, child: Widget, actions: [Widget], width: Int, on_dismiss: fn(EventContext)) Widget {
  _dialog(
    title, child, actions, width,
    fn(ctx: EventContextHandle) { on_dismiss(EventContext{handle: ctx}) },
  )
}

// ── ModalBarrier ──────────────────────────────────────────────────────

extern fn _modal_barrier(fg: Int, bg: Int, ul_color: Int, ul_style: Int, attrs: Int, opacity: Int) Widget = "UiModalBarrier"

fn modal_barrier(bg: Int, opacity: Int) Widget {
  _modal_barrier(-1, bg, -1, 0, 0, opacity)
}

// ── ListTile ──────────────────────────────────────────────────────────

extern fn _list_tile(title: Widget, selected: Bool, disabled: Bool, on_pressed: fn(EventContextHandle)) Widget = "UiListTile"

fn list_tile(title: Widget, selected: Bool, disabled: Bool?, on_pressed: fn(EventContext)) Widget {
  mut d = false
  match disabled {
    v => { d = v },
    _ => {},
  }
  _list_tile(
    title, selected, d,
    fn(ctx: EventContextHandle) { on_pressed(EventContext{handle: ctx}) },
  )
}

// ── Overlay ───────────────────────────────────────────────────────────

extern type OverlayEntry = "ffi.UiOverlayEntry"

extern fn _overlay(child: Widget, entries: [OverlayEntry]) Widget = "UiOverlay"
extern fn _overlay_entry(child: Widget, modal: Bool, align_x: Int, align_y: Int) OverlayEntry = "UiMakeOverlayEntry"

fn overlay_entry(child: Widget, modal: Bool, align_x: Int, align_y: Int) OverlayEntry {
  _overlay_entry(child, modal, align_x, align_y)
}

fn overlay(child: Widget, entries: [OverlayEntry]) Widget {
  _overlay(child, entries)
}

fn overlay_modal(child: Widget, modal_child: Widget) Widget {
  _overlay(child, [_overlay_entry(modal_child, true, 0, 0)])
}

// ── Selection ─────────────────────────────────────────────────────────

extern fn _selection_area(child: Widget) Widget = "UiSelectionArea"
extern fn _selection_container(child: Widget, disabled: Bool) Widget = "UiSelectionContainer"

fn selection_area(child: Widget) Widget { _selection_area(child) }
fn selection_container(child: Widget, disabled: Bool?) Widget {
  mut d = false
  match disabled {
    v => { d = v },
    _ => {},
  }
  _selection_container(child, d)
}

// ── CommandPalette ────────────────────────────────────────────────────

extern type CmdItem = "ffi.UiCommandPaletteItem"

extern fn _command_palette(
  items: [CmdItem],
  placeholder: Str,
  empty_text: Str,
  width: Int,
  max_visible_rows: Int,
  on_dismiss: fn(EventContextHandle),
  on_selected: fn(EventContextHandle, Str),
) Widget = "UiCommandPalette"
extern fn _cmd_item(title: Str, description: Str, aliases: [Str]) CmdItem = "UiMakeCmdItem"

fn cmd_item(title: Str, description: Str) CmdItem {
  _cmd_item(title, description, [])
}

fn command_palette(
  items: [CmdItem],
  placeholder: Str,
  empty_text: Str,
  width: Int,
  max_visible_rows: Int,
  on_dismiss: fn(EventContext),
  on_selected: fn(EventContext, Str),
) Widget {
  _command_palette(
    items, placeholder, empty_text, width, max_visible_rows,
    fn(ctx: EventContextHandle) { on_dismiss(EventContext{handle: ctx}) },
    fn(ctx: EventContextHandle, title: Str) { on_selected(EventContext{handle: ctx}, title) },
  )
}

