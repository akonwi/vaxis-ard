}

// ── Cursor ────────────────────────────────────────────────────────────

enum CursorShape {
  default,
  block_blinking,
  block,
  underline_blinking,
  underline,
  beam_blinking,
  beam,
}

impl CursorShape {
  fn to_int() Int {
    match self {
      CursorShape::default => 0,
      CursorShape::block_blinking => 1,
      CursorShape::block => 2,
      CursorShape::underline_blinking => 3,
      CursorShape::underline => 4,
      CursorShape::beam_blinking => 5,
      CursorShape::beam => 6,
    }
  }
}

extern fn _cursor(col: Int, row: Int, shape: Int, hidden: Bool, child: Widget) Widget = "UiCursor"

fn cursor(col: Int, row: Int, shape: CursorShape?, hidden: Bool?, child: Widget) Widget {
  _cursor(col, row, shape.or(CursorShape::default).to_int(), hidden.or(false), child)
}

// ── Animation ─────────────────────────────────────────────────────────

extern type AnimationController = "*ui.AnimationController"

extern fn _anim_new(state_ctx: StateHandle, duration_ms: Int, curve: Int) AnimationController = "UiNewAnimation"
extern fn _anim_forward(ctrl: AnimationController) Void = "UiAnimForward"
extern fn _anim_reset(ctrl: AnimationController) Void = "UiAnimReset"
extern fn _anim_stop(ctrl: AnimationController) Void = "UiAnimStop"
extern fn _anim_value(ctrl: AnimationController) Float = "UiAnimValue"
extern fn _anim_status(ctrl: AnimationController) Int = "UiAnimStatus"

extern fn float_to_int(f: Float) Int = "UiFloatToInt"

enum AnimationCurve { linear, ease_in_out }

impl AnimationCurve {
  fn to_int() Int {
    match self {
      AnimationCurve::linear => 0,
      AnimationCurve::ease_in_out => 1,
    }
  }
}

enum AnimationStatus { idle, forward, completed }

fn _animation_status_from_int(value: Int) AnimationStatus {
  if value == 1 { AnimationStatus::forward }
  else if value == 2 { AnimationStatus::completed }
  else { AnimationStatus::idle }
}

fn animation_controller(ctx: BuildContext, duration_ms: Int, curve: AnimationCurve?) AnimationController {
  let handle = ctx.state.expect("animation_controller requires a stateful BuildContext")
  _anim_new(handle, duration_ms, curve.or(AnimationCurve::linear).to_int())
}

fn anim_forward(ctrl: AnimationController) { _anim_forward(ctrl) }
fn anim_reset(ctrl: AnimationController) { _anim_reset(ctrl) }
fn anim_stop(ctrl: AnimationController) { _anim_stop(ctrl) }
fn anim_value(ctrl: AnimationController) Float { _anim_value(ctrl) }
fn anim_status(ctrl: AnimationController) AnimationStatus {
  _animation_status_from_int(_anim_status(ctrl))
}

// ── ProgressBar ───────────────────────────────────────────────────────

extern fn _progress_bar(
  value: Float, width: Int,
  filled_fg: Int, filled_bg: Int, filled_attrs: Int,
  empty_fg: Int, empty_bg: Int, empty_attrs: Int,
  gradient_start: Int, gradient_end: Int,
) Widget = "UiProgressBar"

fn progress_bar(
  value: Float, width: Int,
  filled_bg: vaxis::Color?, empty_bg: vaxis::Color?,
  gradient_start: vaxis::Color?, gradient_end: vaxis::Color?,
) Widget {
  _progress_bar(value, width,
    -1, vaxis::color_to_int(filled_bg.or(vaxis::COLOR_DEFAULT)), 0,
    -1, vaxis::color_to_int(empty_bg.or(vaxis::COLOR_DEFAULT)), 0,
    vaxis::color_to_int(gradient_start.or(vaxis::COLOR_DEFAULT)),
    vaxis::color_to_int(gradient_end.or(vaxis::COLOR_DEFAULT)))
}

// ── RichText ──────────────────────────────────────────────────────────

// Text layout enums are declared up here so rich_text() below can take
// optional `overflow` and `max_lines` arguments. plain text() down in the
// "Basic widgets" section uses the same enums.
enum TextAlign { start, end, left, right, center }

impl TextAlign {
  fn to_int() Int {
    match self {
      TextAlign::start => 0, TextAlign::end => 1,
      TextAlign::left => 2, TextAlign::right => 3, TextAlign::center => 4,
    }
  }
}

enum TextOverflow { clip, ellipsis, visible }

impl TextOverflow {
  fn to_int() Int {
    match self {
      TextOverflow::clip => 0, TextOverflow::ellipsis => 1, TextOverflow::visible => 2,
    }
  }
}

extern type TextSpan = "ffi.UiTextSpan"

extern fn _rich_text(
  spans: [TextSpan], soft_wrap: Bool, overflow: Int, max_lines: Int,
) Widget = "UiRichText"
extern fn _span(
  text: Str, attrs: Int, fg: Int, bg: Int, ul_style: Int,
  hyperlink: Str, has_on_pressed: Bool, on_pressed: fn(EventContextHandle),
) TextSpan = "UiMakeSpan"

fn span(
  text: Str, attrs: TextAttrs?, fg: vaxis::Color?, bg: vaxis::Color?,
  underline: Bool?, hyperlink: Str?, on_pressed: fn(EventContext)?,
) TextSpan {
  let cb = on_pressed.or(fn(_: EventContext) {})
  mut ul_style = 0
  if underline.or(false) { ul_style = 1 }
  _span(text, attrs.or(TextAttrs{}).to_int(),
    vaxis::color_to_int(fg.or(vaxis::COLOR_DEFAULT)),
    vaxis::color_to_int(bg.or(vaxis::COLOR_DEFAULT)),
    ul_style, hyperlink.or(""),
    on_pressed.is_some(),
    fn(c: EventContextHandle) { cb(EventContext{handle: c}) })
}

fn rich_text(
  spans: [TextSpan], soft_wrap: Bool?, overflow: TextOverflow?, max_lines: Int?,
) Widget {
  _rich_text(
    spans,
    soft_wrap.or(false),
    overflow.or(TextOverflow::clip).to_int(),
    max_lines.or(0),
  )
}

// ── Basic widgets ─────────────────────────────────────────────────────

extern fn _text(
  value: Str, soft_wrap: Bool, align: Int, overflow: Int, max_lines: Int,
  has_on_pressed: Bool, on_pressed: fn(EventContextHandle), click_affordance: Int,
) Widget = "UiText"
extern fn _button(label: Str, on_pressed: fn(EventContextHandle)) Widget = "UiButton"
extern fn _styled_text(
  value: Str, fg: Int, bg: Int, ul_color: Int, ul_style: Int, attrs: Int,
  has_on_pressed: Bool, on_pressed: fn(EventContextHandle), click_affordance: Int,
) Widget = "UiStyledText"

// Controls the visual affordance added when a Text widget has an on_pressed
// callback. Mirrors upstream `ui.ClickAffordance`.
//
// - `default`   : underline clickable text unless its style already specifies
//                 an underline (vaxis upstream default).
// - `underline` : always underline clickable text.
// - `none`      : leave the caller-provided style unchanged; also suppresses
//                 the focused-span underline. Use this when the click target
//                 already has its own visual treatment (tab labels, list
//                 rows, etc.).
enum ClickAffordance { default, underline, none }

impl ClickAffordance {
  fn to_int() Int {
    match self {
      ClickAffordance::default => 0,
      ClickAffordance::underline => 1,
      ClickAffordance::none => 2,
    }
  }
}

fn text(
  value: Str, soft_wrap: Bool?, align: TextAlign?, overflow: TextOverflow?, max_lines: Int?,
  on_pressed: fn(EventContext)?, click_affordance: ClickAffordance?,
) Widget {
  let cb = on_pressed.or(fn(_c: EventContext) {})
  _text(value, soft_wrap.or(false), align.or(TextAlign::start).to_int(),
    overflow.or(TextOverflow::clip).to_int(), max_lines.or(0),
    on_pressed.is_some(),
    fn(ctx: EventContextHandle) { cb(EventContext{handle: ctx}) },
    click_affordance.or(ClickAffordance::default).to_int())
}

fn styled_text(
  value: Str, fg: vaxis::Color?, bg: vaxis::Color?, attrs: TextAttrs?,
  on_pressed: fn(EventContext)?, click_affordance: ClickAffordance?,
) Widget {
  let cb = on_pressed.or(fn(_c: EventContext) {})
  _styled_text(value,
    vaxis::color_to_int(fg.or(vaxis::COLOR_DEFAULT)),
    vaxis::color_to_int(bg.or(vaxis::COLOR_DEFAULT)),
    -1, 0, attrs.or(TextAttrs{}).to_int(),
    on_pressed.is_some(),
    fn(ctx: EventContextHandle) { cb(EventContext{handle: ctx}) },
    click_affordance.or(ClickAffordance::default).to_int())
}

fn button(label: Str, on_pressed: fn(EventContext)) Widget {
  _button(label, fn(ctx: EventContextHandle) { on_pressed(EventContext{handle: ctx}) })
}

