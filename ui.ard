}

// ── RichText ──────────────────────────────────────────────────────────

extern type TextSpan = "ffi.UiTextSpan"

extern fn _rich_text(spans: [TextSpan], soft_wrap: Bool) Widget = "UiRichText"
extern fn _span(text: Str, fg: Int, bg: Int, attrs: Int) TextSpan = "UiMakeSpan"

fn span(text: Str, attrs: Int) TextSpan {
  _span(text, -1, -1, attrs)
}

fn rich_text(spans: [TextSpan], soft_wrap: Bool?) Widget {
  mut sw = false
  match soft_wrap {
    v => { sw = v },
    _ => {},
  }
  _rich_text(spans, sw)
}

// ── Basic widgets ─────────────────────────────────────────────────────

extern fn _text(value: Str, soft_wrap: Bool) Widget   = "UiText"
extern fn _button(label: Str, on_pressed: fn(EventContextHandle)) Widget   = "UiButton"

extern fn _styled_text(value: Str, fg: Int, bg: Int, ul_color: Int, ul_style: Int, attrs: Int) Widget = "UiStyledText"

fn text(value: Str, soft_wrap: Bool?) Widget { _text(value, soft_wrap.or(false)) }

fn styled_text(value: Str, fg: Int, bg: Int, attrs: Int) Widget {
  _styled_text(value, fg, bg, -1, 0, attrs)
}

fn button(label: Str, on_pressed: fn(EventContext)) Widget {
  _button(
    label,
    fn(ctx: EventContextHandle) { on_pressed(EventContext{handle: ctx}) },
  )
}

// ── Checkbox ──────────────────────────────────────────────────────────

extern fn _checkbox(checked: Bool, disabled: Bool, label: Str, on_changed: fn(EventContextHandle, Bool)) Widget = "UiCheckbox"

fn checkbox(checked: Bool, label: Str, disabled: Bool?, on_changed: fn(EventContext, Bool)) Widget {
  mut d = false
  match disabled {
    v => { d = v },
    _ => {},
  }
  _checkbox(
    checked, d, label,
    fn(ctx: EventContextHandle, next: Bool) {
      on_changed(EventContext{handle: ctx}, next)
    },
  )
}

// ── Radio ─────────────────────────────────────────────────────────────

extern fn _radio(value: Str, group_value: Str, disabled: Bool, label: Str, on_changed: fn(EventContextHandle, Str)) Widget = "UiRadio"

fn radio(value: Str, group_value: Str, label: Str, on_changed: fn(EventContext, Str)) Widget {
  _radio(
    value, group_value, false, label,
    fn(ctx: EventContextHandle, next: Str) {
      on_changed(EventContext{handle: ctx}, next)
    },
  )
}

// ── SegmentedControl ─────────────────────────────────────────────────

extern type SegmentedItem = "ffi.UiSegmentedItem"

extern fn _segmented_control(value: Str, segments: [SegmentedItem], disabled: Bool, on_changed: fn(EventContextHandle, Str)) Widget = "UiSegmentedControl"
extern fn _segmented_item(value: Str, label: Str, disabled: Bool) SegmentedItem = "UiMakeSegmentedItem"

fn segment(value: Str, label: Str) SegmentedItem {
  _segmented_item(value, label, false)
}

fn segmented_control(value: Str, segments: [SegmentedItem], on_changed: fn(EventContext, Str)) Widget {
  _segmented_control(
    value, segments, false,
    fn(ctx: EventContextHandle, next: Str) {
      on_changed(EventContext{handle: ctx}, next)
    },
  )
}

// ── Divider ───────────────────────────────────────────────────────────

extern fn _divider() Widget   = "UiDivider"

fn divider() Widget { _divider() }

// ── Text input ───────────────────────────────────────────────────────

extern fn _text_field(
  value: Str,
  placeholder: Str,
  min_width: Int,
  obscure: Bool,
  on_changed: fn(EventContextHandle, Str),
  on_submitted: fn(EventContextHandle, Str),
) Widget = "UiTextField"

fn text_field(
  value: Str,
  placeholder: Str,
  min_width: Int,
  obscure: Bool,
  on_changed: fn(EventContext, Str),
  on_submitted: fn(EventContext, Str),
) Widget {
  _text_field(
    value,
    placeholder,
    min_width,
    obscure,
    fn(ctx: EventContextHandle, next: Str) { on_changed(EventContext{handle: ctx}, next) },
    fn(ctx: EventContextHandle, submitted: Str) { on_submitted(EventContext{handle: ctx}, submitted) },
  )
}

// ── TextArea ──────────────────────────────────────────────────────────

extern fn _text_area(
  value: Str,
  placeholder: Str,
  min_width: Int,
  min_height: Int,
  soft_wrap: Bool,
  on_changed: fn(EventContextHandle, Str),
) Widget = "UiTextArea"

fn text_area(
  value: Str,
  placeholder: Str,
  min_width: Int,
  min_height: Int,
  soft_wrap: Bool,
  on_changed: fn(EventContext, Str),
) Widget {
  _text_area(
    value,
    placeholder,
    min_width,
    min_height,
    soft_wrap,
    fn(ctx: EventContextHandle, next: Str) { on_changed(EventContext{handle: ctx}, next) },
  )
}

// ── Scroll ───────────────────────────────────────────────────────────

extern fn _scroll_view(child: Widget) Widget = "UiScrollView"
extern fn _scrollbar(axis: Int, child: Widget) Widget = "UiScrollbar"

extern type ScrollPaneController = "*ui.ScrollPaneController"

extern fn _scroll_pane_controller() ScrollPaneController = "UiScrollPaneController"
extern fn _scroll_pane(controller: ScrollPaneController, child: Widget) Widget = "UiScrollPane"
extern fn _scroll_pane_scroll_by(controller: ScrollPaneController, cols: Int, rows: Int) Bool = "UiScrollPaneScrollBy"
extern fn _scroll_pane_scroll_to(controller: ScrollPaneController, col: Int, row: Int) Bool = "UiScrollPaneScrollTo"

fn scroll_view(child: Widget) Widget { _scroll_view(child) }

let SCROLL_VERTICAL = 0
let SCROLL_HORIZONTAL = 1

fn scrollbar(axis: Int, child: Widget) Widget { _scrollbar(axis, child) }

fn scroll_pane_controller() ScrollPaneController { _scroll_pane_controller() }

fn scroll_pane(controller: ScrollPaneController, child: Widget) Widget {
  _scroll_pane(controller, child)
}

fn scroll_pane_scroll_by(controller: ScrollPaneController, cols: Int, rows: Int) Bool {
  _scroll_pane_scroll_by(controller, cols, rows)
}

fn scroll_pane_scroll_to(controller: ScrollPaneController, col: Int, row: Int) Bool {
  _scroll_pane_scroll_to(controller, col, row)
}

// ── CustomScrollView / Slivers ────────────────────────────────────────

extern type ScrollController = "*ui.ScrollController"

extern fn _scroll_controller() ScrollController = "UiScrollController"
extern fn _scroll_controller_scroll_by_lines(controller: ScrollController, lines: Int) Bool = "UiScrollControllerScrollByLines"
extern fn _scroll_controller_scroll_to_offset(controller: ScrollController, row: Int) Bool = "UiScrollControllerScrollToOffset"
extern fn _scroll_controller_scroll_to_start(controller: ScrollController) Bool = "UiScrollControllerScrollToStart"
extern fn _scroll_controller_scroll_to_end(controller: ScrollController) Bool = "UiScrollControllerScrollToEnd"

extern fn _custom_scroll_view(controller: ScrollController, slivers: [Widget]) Widget = "UiCustomScrollView"
extern fn _sliver_to_box(child: Widget) Widget = "UiSliverToBox"
extern fn _sliver_pinned_header(child: Widget) Widget = "UiSliverPinnedHeader"
extern fn _sliver_fill_remaining(child: Widget) Widget = "UiSliverFillRemaining"
extern fn _sliver_list(children: [Widget]) Widget = "UiSliverList"

fn scroll_controller() ScrollController { _scroll_controller() }
fn scroll_controller_scroll_by_lines(c: ScrollController, lines: Int) Bool { _scroll_controller_scroll_by_lines(c, lines) }
fn scroll_controller_scroll_to_offset(c: ScrollController, row: Int) Bool { _scroll_controller_scroll_to_offset(c, row) }
fn scroll_controller_scroll_to_start(c: ScrollController) Bool { _scroll_controller_scroll_to_start(c) }
fn scroll_controller_scroll_to_end(c: ScrollController) Bool { _scroll_controller_scroll_to_end(c) }

fn custom_scroll_view(controller: ScrollController, slivers: [Widget]) Widget {
  _custom_scroll_view(controller, slivers)
}

fn sliver_to_box(child: Widget) Widget { _sliver_to_box(child) }
fn sliver_pinned_header(child: Widget) Widget { _sliver_pinned_header(child) }
fn sliver_fill_remaining(child: Widget) Widget { _sliver_fill_remaining(child) }
fn sliver_list(children: [Widget]) Widget { _sliver_list(children) }

// ── Actions ───────────────────────────────────────────────────────────

extern fn _actions(child: Widget, bindings: [ActionBinding]) Widget   = "UiActions"
extern fn _shortcuts(child: Widget, bindings: [Str:Str]) Widget   = "UiShortcuts"

fn action(name: Str, handler: fn(EventContext, Str) EventResult) ActionBinding {
  _action_binding(
    name,
    fn(ctx: EventContextHandle, intent: Str) Int {
      match handler(EventContext{handle: ctx}, intent) {
        EventResult::handled => 1,
        EventResult::ignored => 0,
      }
    },
  )
}

fn actions(child: Widget, bindings: [ActionBinding]) Widget {
  _actions(child, bindings)
}

fn shortcuts(child: Widget, bindings: [Str:Str]) Widget {
  _shortcuts(child, bindings)
}

// ── Focus ─────────────────────────────────────────────────────────────

extern fn _focus(child: Widget) Widget   = "UiFocus"
extern fn _focus_scope(child: Widget, trap: Bool, auto_focus: Bool) Widget   = "UiFocusScope"

fn focus(child: Widget) Widget { _focus(child) }

fn focus_scope(child: Widget, trap: Bool, auto_focus: Bool) Widget {
  _focus_scope(child, trap, auto_focus)
}

// ── Stateful widget ───────────────────────────────────────────────────

extern fn _stateful<$T>(
  key: Str,
  init: fn(BuildContextHandle, StateHandle) $T,
  build: fn(BuildContextHandle, StateHandle) Widget,
) Widget   = "UiStateful"

extern fn _state_value<$T>(ctx: StateHandle) $T   = "UiStateValue"
extern fn _state_set_value<$T>(ctx: StateHandle, value: $T) Void   = "UiStateSetValue"

// Runtime is vaxis/ui's UI-thread dispatcher. We type it by `$T` so
// dispatched callbacks get `State<$T>` directly.
extern type RuntimeHandle = "ui.Runtime"
extern fn _build_context_runtime(ctx: BuildContextHandle) RuntimeHandle = "UiBuildContextRuntime"
extern fn _runtime_dispatch(
  runtime: RuntimeHandle,
  state: StateHandle,
  callback: fn(StateHandle),
) Void = "UiRuntimeDispatch"

struct BuildContext {
  handle: BuildContextHandle,
  state: StateHandle?,
}

struct State<$T> {
  handle: StateHandle,
}

impl State {
  fn value() $T {
    _state_value<$T>(self.handle)
  }

  fn set(mutate: fn(mut $T)) {
    mut next = self.value()
    mutate(next)
    _state_set_value(self.handle, next)
  }
}

// Runtime<$T> is a typed re-entry point for background work to update state.
// Get one via `ctx.runtime<$T>()` from inside `stateful`'s `init` or `build`.
struct Runtime<$T> {
  handle: RuntimeHandle,
  state: StateHandle?,
}

impl Runtime {
  // Schedule `callback` on the UI thread. The callback receives the
  // typed `State<$T>` so it can call `.set(...)` directly. If the
  // owning stateful widget has unmounted, the dispatch is a no-op.
  fn dispatch(callback: fn(State<$T>)) {
    match self.state {
      h => _runtime_dispatch(
        self.handle,
        h,
        fn(state_handle: StateHandle) {
          callback(State{handle: state_handle})
        },
      ),
      _ => {},
    }
  }
}

impl BuildContext {
  fn runtime<$T>() Runtime<$T> {
    Runtime{handle: _build_context_runtime(self.handle), state: self.state}
  }
}

fn stateful<$T>(
  key: Str,
  init: fn(BuildContext) $T,
  build: fn(BuildContext, State<$T>) Widget,
) Widget {
  _stateful(
    key: key,
    init: fn(build_ctx: BuildContextHandle, state_handle: StateHandle) $T {
      init(BuildContext{handle: build_ctx, state: state_handle})
    },
    build: fn(build_ctx: BuildContextHandle, state_handle: StateHandle) Widget {
      build(
        BuildContext{handle: build_ctx, state: state_handle},
        State{handle: state_handle},
      )
    },
  )
}
