// ── Animation ─────────────────────────────────────────────────────────

extern type AnimationController = "*ui.AnimationController"

extern fn _anim_new(state_ctx: StateHandle, duration_ms: Int, curve: Int) AnimationController = "UiNewAnimation"
extern fn _anim_forward(ctrl: AnimationController) Void = "UiAnimForward"
extern fn _anim_reset(ctrl: AnimationController) Void = "UiAnimReset"
extern fn _anim_stop(ctrl: AnimationController) Void = "UiAnimStop"
extern fn _anim_value(ctrl: AnimationController) Float = "UiAnimValue"
extern fn _anim_status(ctrl: AnimationController) Int = "UiAnimStatus"

// Float-to-Int workaround: Ard compiler <= v0.23.0 lacks the AIR lowering
// for `Float.to_int()`. Drop this once the upstream fix ships.
extern fn float_to_int(f: Float) Int = "UiFloatToInt"

enum AnimationCurve {
  linear,
  ease_in_out,
}

impl AnimationCurve {
  fn to_int() Int {
    match self {
      AnimationCurve::linear      => 0,
      AnimationCurve::ease_in_out => 1,
    }
  }
}

enum AnimationStatus {
  idle,
  forward,
  completed,
}

// AnimationStatus has no `to_int` (we never write it back) — only a
// constructor from the FFI int. Free function because Ard's `::`
// syntax is for enum variants, not static methods.
fn _animation_status_from_int(value: Int) AnimationStatus {
  if value == 1 { AnimationStatus::forward }
  else if value == 2 { AnimationStatus::completed }
  else { AnimationStatus::idle }
}

// animation_controller must be created inside `init` (or later in `build`)
// where ctx.state is set — it needs the underlying StateBase to register
// the controller with the element's animation list. Calling it elsewhere
// will panic at the FFI boundary.
fn animation_controller(
  ctx: BuildContext,
  duration_ms: Int,
  curve: AnimationCurve?,
) AnimationController {
  let handle = ctx.state.expect("animation_controller requires a stateful BuildContext")
  _anim_new(handle, duration_ms, curve.or(AnimationCurve::linear).to_int())
}

fn anim_forward(ctrl: AnimationController) { _anim_forward(ctrl) }
fn anim_reset(ctrl: AnimationController) { _anim_reset(ctrl) }
fn anim_stop(ctrl: AnimationController) { _anim_stop(ctrl) }
fn anim_value(ctrl: AnimationController) Float { _anim_value(ctrl) }
fn anim_status(ctrl: AnimationController) AnimationStatus {
  _animation_status_from_int(_anim_status(ctrl))
}

// ── ProgressBar ───────────────────────────────────────────────────────

extern fn _progress_bar(
  value: Float,
  width: Int,
  filled_fg: Int, filled_bg: Int, filled_attrs: Int,
  empty_fg: Int, empty_bg: Int, empty_attrs: Int,
  gradient_start: Int, gradient_end: Int,
) Widget = "UiProgressBar"

// Pass gradient_start / gradient_end for a gradient-filled bar; vaxis
// interpolates the fill across them. Otherwise solid filled_bg / empty_bg
// (or theme defaults if -1).
fn progress_bar(
  value: Float,
  width: Int,
  filled_bg: Int?,
  empty_bg: Int?,
  gradient_start: Int?,
  gradient_end: Int?,
) Widget {
  _progress_bar(
    value, width,
    -1, filled_bg.or(-1), 0,
    -1, empty_bg.or(-1), 0,
    gradient_start.or(-1),
    gradient_end.or(-1),
  )
}

// ── RichText ──────────────────────────────────────────────────────────

extern type TextSpan = "ffi.UiTextSpan"

extern fn _rich_text(spans: [TextSpan], soft_wrap: Bool) Widget = "UiRichText"
extern fn _span(
  text: Str,
  attrs: Int,
  fg: Int,
  bg: Int,
  ul_style: Int,
  hyperlink: Str,
  has_on_pressed: Bool,
  on_pressed: fn(EventContextHandle),
) TextSpan = "UiMakeSpan"

// Build a styled run of text for use in rich_text. Everything past the
// text itself is optional:
//   attrs       — vaxis attribute bitmask (use bold(), italic() helpers)
//   fg / bg     — colors; -1 means "inherit from theme"
//   underline   — true sets single underline (most common case)
//   hyperlink   — OSC 8 URL; turns the span into a terminal link
//   on_pressed  — mouse/keyboard activation callback
fn span(
  text: Str,
  attrs: TextAttrs?,
  fg: Int?,
  bg: Int?,
  underline: Bool?,
  hyperlink: Str?,
  on_pressed: fn(EventContext)?,
) TextSpan {
  let has_cb = on_pressed.is_some()
  let cb = on_pressed.or(fn(_: EventContext) {})
  let wrapped_cb = fn(c: EventContextHandle) { cb(EventContext{handle: c}) }
  mut ul_style = 0
  if underline.or(false) { ul_style = 1 }
  _span(
    text,
    attrs.or(TextAttrs{}).to_int(),
    fg.or(-1),
    bg.or(-1),
    ul_style,
    hyperlink.or(""),
    has_cb,
    wrapped_cb,
  )
}

fn rich_text(spans: [TextSpan], soft_wrap: Bool?) Widget {
  mut sw = false
  match soft_wrap {
    v => { sw = v },
    _ => {},
  }
  _rich_text(spans, sw)
}

// ── Basic widgets ─────────────────────────────────────────────────────

extern fn _text(
  value: Str,
  soft_wrap: Bool,
  align: Int,
  overflow: Int,
  max_lines: Int,
) Widget = "UiText"
extern fn _button(label: Str, on_pressed: fn(EventContextHandle)) Widget   = "UiButton"

extern fn _styled_text(value: Str, fg: Int, bg: Int, ul_color: Int, ul_style: Int, attrs: Int) Widget = "UiStyledText"

// Text styling and layout enums. Map at the FFI boundary; vaxis ints
// stay an implementation detail.

enum TextAlign {
  start,
  end,
  left,
  right,
  center,
}

impl TextAlign {
  fn to_int() Int {
    match self {
      TextAlign::start => 0,
      TextAlign::end => 1,
      TextAlign::left => 2,
      TextAlign::right => 3,
      TextAlign::center => 4,
    }
  }
}

enum TextOverflow {
  clip,
  ellipsis,
  visible,
}

impl TextOverflow {
  fn to_int() Int {
    match self {
      TextOverflow::clip => 0,
      TextOverflow::ellipsis => 1,
      TextOverflow::visible => 2,
    }
  }
}

// max_lines defaults to 0 = no limit (matches vaxis Text.MaxLines zero value).
fn text(
  value: Str,
  soft_wrap: Bool?,
  align: TextAlign?,
  overflow: TextOverflow?,
  max_lines: Int?,
) Widget {
  _text(
    value,
    soft_wrap.or(false),
    align.or(TextAlign::start).to_int(),
    overflow.or(TextOverflow::clip).to_int(),
    max_lines.or(0),
  )
}

fn styled_text(
  value: Str,
  fg: Int?,
  bg: Int?,
  attrs: TextAttrs?,
) Widget {
  _styled_text(value, fg.or(-1), bg.or(-1), -1, 0, attrs.or(TextAttrs{}).to_int())
}

fn button(label: Str, on_pressed: fn(EventContext)) Widget {
  _button(
    label,
    fn(ctx: EventContextHandle) { on_pressed(EventContext{handle: ctx}) },
  )
}

